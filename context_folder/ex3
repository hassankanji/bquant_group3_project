class TurkeyOISData:
    @staticmethod
    def snapshot() -> pd.DataFrame:
        return pd.DataFrame(
            SHORT_OIS_SNAPSHOT,
            columns=["tenor", "ticker", "par_rate", "days"],
        ).assign(source="Snapshot 2026-07-09")

    @staticmethod
    def live() -> pd.DataFrame:
        if not HAS_BQL:
            raise RuntimeError("BQL is unavailable.")

        tickers = [row[1] for row in SHORT_OIS_SNAPSHOT]
        ticker_to_tenor = {row[1]: row[0] for row in SHORT_OIS_SNAPSHOT}
        tenor_to_days = {row[0]: row[3] for row in SHORT_OIS_SNAPSHOT}

        request = bql.Request(tickers, {"par_rate": BQ.data.px_last()})
        raw = BQ.execute(request)[0].df().reset_index()

        id_col = "ID" if "ID" in raw.columns else raw.columns[0]
        value_col = "par_rate" if "par_rate" in raw.columns else raw.columns[-1]

        df = pd.DataFrame({
            "ticker": raw[id_col].astype(str),
            "par_rate": pd.to_numeric(raw[value_col], errors="coerce"),
        })
        df["tenor"] = df["ticker"].map(ticker_to_tenor)
        df["days"] = df["tenor"].map(tenor_to_days)
        df["source"] = "Live BQL"
        return (
            df.dropna(subset=["tenor", "days", "par_rate"])
              .sort_values("days")
              .reset_index(drop=True)
        )

    @staticmethod
    def live_policy_rate() -> float:
        if not HAS_BQL:
            raise RuntimeError("BQL is unavailable.")

        request = bql.Request([POLICY_TICKER], {"policy": BQ.data.px_last()})
        raw = BQ.execute(request)[0].df().reset_index()
        value_col = "policy" if "policy" in raw.columns else raw.columns[-1]
        value = pd.to_numeric(raw[value_col], errors="coerce").iloc[0]
        if pd.isna(value):
            raise RuntimeError("Policy ticker returned a non-numeric value.")
        return float(value)


# ============================================================
# 3. SMOOTH MARKET DISCOUNT CURVE
# ============================================================

class ShortOISCurve:
    """
    All maturities are <= 1Y, so the fixed leg is treated as one bullet payment.

    Par OIS condition:
        S * alpha * DF(T) = 1 - DF(T)

    Therefore:
        DF(T) = 1 / (1 + S * alpha)

    Interpolation is applied to LOG DISCOUNT FACTORS, not to policy rates.
    """

    @staticmethod
    def build(quotes: pd.DataFrame, settings: ModelSettings):
        curve = quotes.copy().sort_values("days").reset_index(drop=True)
        curve["par_rate"] = pd.to_numeric(curve["par_rate"], errors="coerce")
        curve = curve.dropna(subset=["par_rate", "days"])

        alpha = curve["days"].to_numpy(float) / settings.day_count_basis
        rates = curve["par_rate"].to_numpy(float) / 100.0
        curve["discount_factor"] = 1.0 / (1.0 + rates * alpha)
        curve["log_discount_factor"] = np.log(curve["discount_factor"])

        node_days = np.r_[0.0, curve["days"].to_numpy(float)]
        node_logdfs = np.r_[0.0, curve["log_discount_factor"].to_numpy(float)]

        logdf_fn = PchipInterpolator(node_days, node_logdfs, extrapolate=True)
        return curve, logdf_fn

    @staticmethod
    def df(logdf_fn, days: int) -> float:
        if days <= 0:
            return 1.0
        return float(np.exp(logdf_fn(float(days))))

    @staticmethod
    def bullet_par_rate(logdf_fn, days: int, settings: ModelSettings) -> float:
        df = ShortOISCurve.df(logdf_fn, days)
        alpha = days / settings.day_count_basis
        return ((1.0 - df) / (alpha * df)) * 100.0


# ============================================================
# 4. STEP-FUNCTION MEETING PATH
# ============================================================

class MeetingStepPath:
    @staticmethod
    def boundary_days() -> np.ndarray:
        days = [(date - AS_OF_DATE).days for date in MEETING_DATES]
        return np.asarray([0] + days + [365], dtype=int)

    @staticmethod
    def df_from_steps(
        target_day: int,
        boundaries: np.ndarray,
        overnight_rates_pct: np.ndarray,
        settings: ModelSettings,
    ) -> float:
        """
        Simple daily-interval compounding under a piecewise-constant rate.
        The rate changes only at CBRT meeting boundaries.
        """
        accumulation = 1.0
        for i, rate in enumerate(overnight_rates_pct):
            start = int(boundaries[i])
            end = int(boundaries[i + 1])
            overlap = max(min(int(target_day), end) - start, 0)
            if overlap > 0:
                accumulation *= (
                    1.0
                    + (float(rate) / 100.0)
                    * (overlap / settings.day_count_basis)
                )
            if target_day <= end:
                break
        return 1.0 / accumulation

    @staticmethod
    def calibrate(
        smooth_logdf_fn,
        effective_overnight_anchor: float,
        policy_rate: float,
        overnight_policy_basis_bps: float,
        settings: ModelSettings,
    ):
        """
        Jointly calibrate all 2026 meeting moves.

        Only 1W–6M instruments are used in the meeting solver because those
        maturities are covered by the supplied 2026 CBRT calendar. 9M and 1Y
        remain validation points: using them without the 2027 meeting calendar
        would incorrectly force longer-horizon easing into the December meeting.
        """
        boundaries = MeetingStepPath.boundary_days()

        calibration_rows = [
            row for row in SHORT_OIS_SNAPSHOT
            if row[0] in CALIBRATION_TENORS
        ]
        validation_rows = [
            row for row in SHORT_OIS_SNAPSHOT
            if row[0] in VALIDATION_TENORS
        ]

        calibration_days = np.asarray([row[3] for row in calibration_rows], dtype=int)
        target_dfs = np.asarray(
            [ShortOISCurve.df(smooth_logdf_fn, day) for day in calibration_days],
            dtype=float,
        )

        # Strongest weight at the front end, where individual meetings are identified.
        weights = 1.0 / np.sqrt(np.maximum(calibration_days, 7) / 7.0)

        # Solve directly for the four policy moves, in basis points.
        # Bounds permit Turkey-sized changes but prevent mathematically convenient
        # multi-hundred-bp oscillations unsupported by the data.
        initial_moves = np.array([-150.0, -100.0, -100.0, -100.0])

        def rates_from_moves(move_bps: np.ndarray) -> np.ndarray:
            policy_after = policy_rate + np.cumsum(move_bps) / 100.0
            overnight_after = policy_after + overnight_policy_basis_bps / 100.0
            return np.r_[effective_overnight_anchor, overnight_after]

        def residuals(move_bps: np.ndarray) -> np.ndarray:
            overnight_rates = rates_from_moves(move_bps)

            pricing_errors = []
            for day, target_df, weight in zip(calibration_days, target_dfs, weights):
                model_df = MeetingStepPath.df_from_steps(
                    day, boundaries, overnight_rates, settings
                )
                alpha = day / settings.day_count_basis
                target_rate = ((1.0 / target_df - 1.0) / alpha) * 100.0
                model_rate = ((1.0 / model_df - 1.0) / alpha) * 100.0
                pricing_errors.append((model_rate - target_rate) * 100.0 * weight)

            # Penalize changes in the size of consecutive meeting moves, not the
            # absolute level of rates. This still allows a sustained cutting cycle.
            second_difference = np.diff(move_bps)
            smooth_penalty = (
                np.sqrt(settings.smoothness_lambda)
                * second_difference
                / settings.standard_move_bps
            )
            return np.r_[pricing_errors, smooth_penalty]

        result = least_squares(
            residuals,
            initial_moves,
            bounds=(
                np.full(4, -500.0),
                np.full(4, 500.0),
            ),
            xtol=1e-13,
            ftol=1e-13,
            gtol=1e-13,
            max_nfev=20000,
        )
        if not result.success:
            raise RuntimeError(f"Meeting calibration failed: {result.message}")

        calibrated_moves = result.x
        overnight_rates = rates_from_moves(calibrated_moves)
        policy_rates = policy_rate + np.cumsum(calibrated_moves) / 100.0

        path_rows = []
        previous_policy = policy_rate
        for i, meeting_date in enumerate(MEETING_DATES):
            post_policy = float(policy_rates[i])
            move_bps = float(calibrated_moves[i])
            move_units = move_bps / settings.standard_move_bps

            path_rows.append({
                "meeting_date": meeting_date,
                "market_move_bps": move_bps,
                "market_policy_rate": post_policy,
                "market_overnight_rate": float(overnight_rates[i + 1]),
                "move_units": move_units,
                "binary_probability_pct_if_applicable": (
                    abs(move_units) * 100.0 if abs(move_units) <= 1.0 else np.nan
                ),
            })
            previous_policy = post_policy

        diagnostic_rows = []
        for tenor, _, _, day in calibration_rows + validation_rows:
            target_df = ShortOISCurve.df(smooth_logdf_fn, day)
            model_df = MeetingStepPath.df_from_steps(
                day, boundaries, overnight_rates, settings
            )
            alpha = day / settings.day_count_basis
            target_rate = ((1.0 / target_df - 1.0) / alpha) * 100.0
            model_rate = ((1.0 / model_df - 1.0) / alpha) * 100.0

            diagnostic_rows.append({
                "tenor": tenor,
                "use": "Calibration" if tenor in CALIBRATION_TENORS else "Validation only",
                "days": day,
                "market_rate": target_rate,
                "step_model_rate": model_rate,
                "fit_error_bps": (model_rate - target_rate) * 100.0,
            })

        return (
            pd.DataFrame(path_rows),
            pd.DataFrame(diagnostic_rows),
            boundaries,
            overnight_rates,
        )


# ============================================================
# 5. USER SCENARIO + SELECTED TRADE
# ============================================================

class ScenarioAndTrade:
    @staticmethod
    def scenario_path(
        market_path: pd.DataFrame,
        policy_rate: float,
        basis_bps: float,
        user_moves_bps: Sequence[float],
    ) -> pd.DataFrame:
        if len(user_moves_bps) != len(market_path):
            raise ValueError("Enter one scenario move per meeting.")

        result = market_path.copy()
        result["user_move_bps"] = [float(x) for x in user_moves_bps]

        running_policy = policy_rate
        user_policy_rates = []
        for move in result["user_move_bps"]:
            running_policy += move / 100.0
            user_policy_rates.append(running_policy)

        result["user_policy_rate"] = user_policy_rates
        result["user_overnight_rate"] = (
            result["user_policy_rate"] + basis_bps / 100.0
        )
        result["user_minus_market_bps"] = (
            result["user_policy_rate"] - result["market_policy_rate"]
        ) * 100.0
        return result

    @staticmethod
    def scenario_segment_rates(
        scenario_path: pd.DataFrame,
        effective_overnight_anchor: float,
    ) -> np.ndarray:
        return np.asarray(
            [effective_overnight_anchor]
            + scenario_path["user_overnight_rate"].tolist(),
            dtype=float,
        )

    @staticmethod
    def bullet_par_rate_from_steps(
        maturity_days: int,
        boundaries: np.ndarray,
        rates: np.ndarray,
        settings: ModelSettings,
    ) -> float:
        df = MeetingStepPath.df_from_steps(
            maturity_days, boundaries, rates, settings
        )
        alpha = maturity_days / settings.day_count_basis
        return ((1.0 - df) / (alpha * df)) * 100.0

    @staticmethod
    def trade_metrics(
        smooth_logdf_fn,
        maturity_days: int,
        boundaries: np.ndarray,
        scenario_rates: np.ndarray,
        notional: float,
        direction: str,
        settings: ModelSettings,
    ) -> pd.DataFrame:
        market_rate = ShortOISCurve.bullet_par_rate(
            smooth_logdf_fn, maturity_days, settings
        )
        scenario_rate = ScenarioAndTrade.bullet_par_rate_from_steps(
            maturity_days, boundaries, scenario_rates, settings
        )

        scenario_df = MeetingStepPath.df_from_steps(
            maturity_days, boundaries, scenario_rates, settings
        )
        alpha = maturity_days / settings.day_count_basis

        fixed_pv = (market_rate / 100.0) * alpha * scenario_df * notional
        floating_pv = (1.0 - scenario_df) * notional
        payer_pv = floating_pv - fixed_pv
        position_pv = payer_pv if direction == "Pay fixed" else -payer_pv

        dv01 = alpha * scenario_df * notional / 10000.0
        gap_bps = (scenario_rate - market_rate) * 100.0

        return pd.DataFrame([{
            "market_rate": market_rate,
            "scenario_fair_rate": scenario_rate,
            "scenario_minus_market_bps": gap_bps,
            "direction": direction,
            "notional_try": notional,
            "dv01_try_per_bp": dv01,
            "scenario_pv_try": position_pv,
            "trade_signal": (
                "Pay fixed" if gap_bps > 1.0
                else "Receive fixed" if gap_bps < -1.0
                else "Near fair"
            ),
        }])


