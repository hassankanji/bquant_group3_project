class TurkeyPolicyPricer:
    def __init__(self):
        self.settings = ModelSettings()

        self.quotes = None
        self.curve = None
        self.logdf_fn = None
        self.market_path = None
        self.diagnostics = None
        self.boundaries = None
        self.market_overnight_rates = None
        self.user_path = None
        self.trade_result = None

        self._build_widgets()

    def _build_widgets(self):
        # Headline inputs
        self.data_source = widgets.ToggleButtons(
            options=["Snapshot", "Live BQL"],
            value="Snapshot",
            description="Data:",
        )
        self.policy_rate = widgets.FloatText(
            value=DEFAULT_POLICY_RATE,
            description="Policy:",
            layout=widgets.Layout(width="210px"),
        )
        self.overnight_anchor = widgets.FloatText(
            value=DEFAULT_EFFECTIVE_OVERNIGHT,
            description="Effective O/N:",
            layout=widgets.Layout(width="235px"),
        )

        # Trade inputs
        self.trade_tenor = widgets.Dropdown(
            options=list(TRADE_TENORS),
            value="6M",
            description="OIS tenor:",
            layout=widgets.Layout(width="220px"),
        )
        self.direction = widgets.Dropdown(
            options=["Pay fixed", "Receive fixed"],
            value="Pay fixed",
            description="Direction:",
            layout=widgets.Layout(width="230px"),
        )
        self.notional = widgets.FloatText(
            value=100_000_000.0,
            description="Notional TRY:",
            layout=widgets.Layout(width="260px"),
        )

        self.refresh_button = widgets.Button(
            description="Refresh market",
            button_style="info",
            icon="refresh",
        )
        self.reprice_button = widgets.Button(
            description="Reprice scenario",
            button_style="success",
            icon="check",
        )
        self.export_button = widgets.Button(
            description="Export",
            icon="download",
        )

        # Scenario entry rows
        self.move_inputs = []
        for date in MEETING_DATES:
            self.move_inputs.append(
                widgets.FloatText(
                    value=0.0,
                    description=date.strftime("%d %b %Y"),
                    layout=widgets.Layout(width="245px"),
                )
            )

        # Technical assumptions hidden by default
        self.basis = widgets.FloatText(
            value=DEFAULT_OVERNIGHT_POLICY_BASIS_BPS,
            description="O/N-policy basis bp:",
            layout=widgets.Layout(width="300px"),
        )
        self.move_size = widgets.FloatText(
            value=self.settings.standard_move_bps,
            description="Standard move bp:",
            layout=widgets.Layout(width="280px"),
        )
        self.smoothing = widgets.FloatText(
            value=self.settings.smoothness_lambda,
            description="Smooth λ:",
            layout=widgets.Layout(width="250px"),
        )

        self.assumptions_box = widgets.VBox([
            widgets.HTML(
                "<b>Technical controls — model governance, not normal daily inputs</b>"
            ),
            widgets.HBox([self.basis, self.move_size, self.smoothing]),
            widgets.HTML(
                "Curve interpolation: shape-preserving interpolation of log discount factors. "
                "Policy interpolation: none; the policy path is stepwise."
            ),
        ])
        self.assumptions = widgets.Accordion(children=[self.assumptions_box])
        self.assumptions.set_title(0, "Model assumptions and diagnostics")

        # Outputs
        self.summary_out = widgets.Output()
        self.market_curve_out = widgets.Output()
        self.table_out = widgets.Output()
        self.chart_out = widgets.Output()
        self.diagnostics_out = widgets.Output()
        self.export_out = widgets.Output()

        self.refresh_button.on_click(lambda _: self.run(refresh=True))
        self.reprice_button.on_click(lambda _: self.run(refresh=False))
        self.export_button.on_click(lambda _: self.export_excel())

    def current_settings(self) -> ModelSettings:
        return ModelSettings(
            day_count_basis=360,
            standard_move_bps=float(self.move_size.value),
            smoothness_lambda=max(float(self.smoothing.value), 0.0),
            max_fit_error_warning_bps=5.0,
        )

    def load_market(self):
        if self.data_source.value == "Live BQL":
            self.quotes = TurkeyOISData.live()
            self.policy_rate.value = TurkeyOISData.live_policy_rate()
        else:
            self.quotes = TurkeyOISData.snapshot()

    def user_moves(self) -> List[float]:
        return [float(widget.value) for widget in self.move_inputs]

    def run(self, refresh: bool = False):
        with self.summary_out:
            clear_output()
            display(HTML("<b>Loading market data and calibrating the meeting path...</b>"))

        try:
            settings = self.current_settings()

            if refresh or self.quotes is None:
                self.load_market()
                self.curve, self.logdf_fn = ShortOISCurve.build(
                    self.quotes, settings
                )

                (
                    self.market_path,
                    self.diagnostics,
                    self.boundaries,
                    self.market_overnight_rates,
                ) = MeetingStepPath.calibrate(
                    self.logdf_fn,
                    float(self.overnight_anchor.value),
                    float(self.policy_rate.value),
                    float(self.basis.value),
                    settings,
                )

            self.user_path = ScenarioAndTrade.scenario_path(
                self.market_path,
                float(self.policy_rate.value),
                float(self.basis.value),
                self.user_moves(),
            )
            scenario_rates = ScenarioAndTrade.scenario_segment_rates(
                self.user_path,
                float(self.overnight_anchor.value),
            )

            self.trade_result = ScenarioAndTrade.trade_metrics(
                self.logdf_fn,
                TRADE_TENORS[self.trade_tenor.value],
                self.boundaries,
                scenario_rates,
                float(self.notional.value),
                self.direction.value,
                settings,
            )

            self.render_summary(settings)
            self.render_market_curve()
            self.render_table()
            self.render_chart()
            self.render_diagnostics()

        except Exception as exc:
            import traceback
            with self.summary_out:
                clear_output()
                display(HTML(
                    "<h3 style='color:#b00020'>Calibration or rendering error</h3>"
                    f"<pre>{traceback.format_exc()}</pre>"
                ))

    def render_summary(self, settings: ModelSettings):
        with self.summary_out:
            clear_output()

            first = self.market_path.iloc[0]
            trade = self.trade_result.iloc[0]
            max_error = self.diagnostics.loc[self.diagnostics["use"] == "Calibration", "fit_error_bps"].abs().max()

            display(HTML(
                f"""
                <div style="border:1px solid #777;padding:14px;border-radius:8px;">
                  <h2 style="margin-top:0;">Turkey OIS Policy Pricer</h2>
                  <b>As of:</b> {AS_OF_DATE.date()} &nbsp; | &nbsp;
                  <b>Policy:</b> {self.policy_rate.value:.2f}% &nbsp; | &nbsp;
                  <b>Effective O/N:</b> {self.overnight_anchor.value:.2f}%<br><br>

                  <b>Next meeting ({first['meeting_date'].date()}):</b>
                  {first['market_move_bps']:+.0f} bp implied,
                  policy-equivalent rate {first['market_policy_rate']:.2f}%<br>

                  <b>Selected trade:</b> {self.direction.value} {self.trade_tenor.value}
                  on TRY {self.notional.value:,.0f}<br>
                  <b>Market rate:</b> {trade['market_rate']:.3f}% &nbsp; | &nbsp;
                  <b>Scenario fair:</b> {trade['scenario_fair_rate']:.3f}% &nbsp; | &nbsp;
                  <b>Gap:</b> {trade['scenario_minus_market_bps']:+.1f} bp<br>
                  <b>DV01:</b> TRY {trade['dv01_try_per_bp']:,.0f}/bp &nbsp; | &nbsp;
                  <b>Scenario P&amp;L:</b> TRY {trade['scenario_pv_try']:,.0f}<br><br>

                  <b>Calibration max error (1W–6M):</b> {max_error:.2f} bp<br>
                  <span style="font-size:0.92em;">
                    9M and 1Y are validation-only until the 2027 CBRT meeting calendar is loaded.
                    Trades marked * use a flat post-December overnight-rate assumption.
                  </span>
                </div>
                """
            ))

    def render_table(self):
        with self.table_out:
            clear_output()

            table = self.market_path[[
                "meeting_date",
                "market_move_bps",
                "market_policy_rate",
            ]].copy()
            table["user_move_bps"] = self.user_moves()
            table["user_policy_rate"] = self.user_path["user_policy_rate"]
            table["user_minus_market_bps"] = self.user_path[
                "user_minus_market_bps"
            ]

            table = table.rename(columns={
                "meeting_date": "CBRT meeting",
                "market_move_bps": "Market move (bp)",
                "market_policy_rate": "Market policy (%)",
                "user_move_bps": "User move (bp)",
                "user_policy_rate": "User policy (%)",
                "user_minus_market_bps": "User - market (bp)",
            })

            display(HTML("<h3>Market-implied path vs user scenario</h3>"))
            display(table.round(2).reset_index(drop=True))

    def render_market_curve(self):
        """Display the actual smooth short-end OIS market curve."""
        with self.market_curve_out:
            clear_output()

            settings = self.current_settings()
            dense_days = np.arange(7, 366)
            dense_rates = [
                ShortOISCurve.bullet_par_rate(
                    self.logdf_fn, int(day), settings
                )
                for day in dense_days
            ]

            fig = go.Figure()
            fig.add_trace(go.Scatter(
                x=dense_days,
                y=dense_rates,
                mode="lines",
                name="Interpolated OIS curve",
                hovertemplate="Day %{x}<br>OIS %{y:.3f}%<extra></extra>",
            ))
            fig.add_trace(go.Scatter(
                x=self.curve["days"],
                y=self.curve["par_rate"],
                mode="markers+text",
                text=self.curve["tenor"],
                textposition="top center",
                name="Market quotes",
                marker={"size": 9},
                hovertemplate="%{text}<br>OIS %{y:.3f}%<extra></extra>",
            ))
            fig.update_layout(
                title="1. TRY short-end OIS market curve",
                xaxis_title="Days to maturity",
                yaxis_title="Par OIS rate (%)",
                height=410,
                hovermode="x unified",
                margin={"l": 65, "r": 35, "t": 65, "b": 55},
            )
            fig.show()

            display(HTML(
                "<div style='padding:8px 0 14px 0;'>"
                "<b>This is the actual market curve.</b> The dots are the quoted "
                "1W–1Y OIS instruments. The smooth line comes from "
                "shape-preserving interpolation of <i>log discount factors</i>."
                "</div>"
            ))

    def render_chart(self):
        with self.chart_out:
            clear_output()

            settings = self.current_settings()
            scenario_rates = ScenarioAndTrade.scenario_segment_rates(
                self.user_path,
                float(self.overnight_anchor.value),
            )

