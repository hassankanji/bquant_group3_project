    def render_diagnostics(self):
        with self.diagnostics_out:
            clear_output()
            display(HTML("<h3>Short-end curve and calibration diagnostics</h3>"))
            display(self.curve[[
                "tenor",
                "ticker",
                "par_rate",
                "discount_factor",
