                "2027 CBRT calendar is added."
            ))

    def export_excel(self):
        with self.export_out:
            clear_output()
            if self.trade_result is None:
                display(HTML("<b>Run the pricer first.</b>"))
                return

            path = Path.cwd() / "turkey_ois_policy_pricer_v4.xlsx"
            with pd.ExcelWriter(path, engine="openpyxl") as writer:
                self.quotes.to_excel(writer, sheet_name="market_quotes", index=False)
                self.curve.to_excel(writer, sheet_name="discount_curve", index=False)
                self.market_path.to_excel(writer, sheet_name="market_path", index=False)
                self.user_path.to_excel(writer, sheet_name="user_scenario", index=False)
                self.trade_result.to_excel(writer, sheet_name="selected_trade", index=False)
                self.diagnostics.to_excel(writer, sheet_name="diagnostics", index=False)

            display(FileLink(str(path)))

