@dataclass(frozen=True)
class ModelSettings:
    day_count_basis: int = 360
    standard_move_bps: float = 250.0
    smoothness_lambda: float = 0.015
    max_fit_error_warning_bps: float = 5.0


# ============================================================
# 2. DATA
