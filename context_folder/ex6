        c = self.config
        profile = CALIBRATION_PROFILES[self.calibration_method.value]

        settings = pd.DataFrame({
            "Item": [
                "Country",
                "Currency",
                "Curve",
                "Instrument",
                "Policy ticker",
                "Day count",
                "Spot lag",
                "Standard move",
                "Calibration tenors",
                "Validation tenors",
                "Trade tenors",
                "Allocation method",
                "Smoothness penalty",
                "Move-size penalty",
                "Front-load penalty",
                "Back-load penalty",
                "Standard-move penalty",
                "Notes",
            ],
            "Value": [
                c.name,
                c.currency,
                c.curve_name,
                c.instrument_name,
                c.policy_ticker,
                f"ACT/{c.day_count_basis}",
                f"{c.spot_lag_days} day(s)",
                f"{c.standard_move_bps:g} bp",
                ", ".join(c.calibration_tenors),
                ", ".join(c.validation_tenors),
