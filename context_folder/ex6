                profile.front_load_lambda,
                profile.back_load_lambda,
                profile.standard_move_lambda,
                c.notes,
            ],
        })

        quote_table = self.quotes[
            ["tenor", "ticker", "par_rate", "tenor_days", "source"]
        ].copy()

        with self.settings_out:
            clear_output()
            display(HTML("<h3>Country Conventions and Assumptions</h3>"))
            display(settings)
            display(HTML("<h3 style='margin-top:24px;'>Market Inputs</h3>"))
            display(quote_table.style.format({"par_rate": "{:.5f}"}))

