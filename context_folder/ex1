    raise ValueError("compounding must be simple or continuous")


def build_curve_functions(curve_df, cfg):
    df = curve_df.copy().sort_values("days").reset_index(drop=True)
    df = df.dropna(subset=["days", "rate"])

    # MVP approximation: treat node rates as zero/par-ish curve points.
    # More exact version should bootstrap actual swap cashflows.
    df["discount_factor"] = zero_rate_to_discount_factor(
        df["rate"],
        df["days"],
        basis=cfg.day_count_basis,
        compounding="simple"
    )
    df["log_discount_factor"] = np.log(df["discount_factor"])

    x = df["days"].values
    y = df["log_discount_factor"].values

    if cfg.interpolation_method == "pchip":
        logdf_fn = PchipInterpolator(x, y, extrapolate=True)
    elif cfg.interpolation_method == "linear":
        logdf_fn = interp1d(x, y, fill_value="extrapolate")
    else:
        raise ValueError("interpolation_method must be pchip or linear")

    return df, logdf_fn


def forward_rate_from_discount_factors(logdf_fn, start_days, end_days, cfg):
    start_days = np.asarray(start_days, dtype=float)
    end_days = np.asarray(end_days, dtype=float)

    df_start = np.exp(logdf_fn(start_days))
    df_end = np.exp(logdf_fn(end_days))
    tau = (end_days - start_days) / cfg.day_count_basis

    return ((df_start / df_end - 1.0) / tau) * 100.0


