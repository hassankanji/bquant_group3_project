def fetch_policy_rate(policy_ticker, fallback_rate):
    """Try to pull policy anchor. If unavailable, use fallback."""
    try:
        req = bql.Request([policy_ticker], {"px": bq.data.px_last()})
        raw = bq.execute(req)[0].df().reset_index()
        value = pd.to_numeric(raw["px"].iloc[0], errors="coerce")
        if pd.notna(value):
            return float(value)
    except Exception:
        pass
    return fallback_rate


def fetch_live_curve(curve_tickers, tenor_days, cfg):
    securities = list(curve_tickers.values())

    req = bql.Request(
        securities,
        {"px": bq.data.px_last()}
    )
    raw = bq.execute(req)[0].df().reset_index()

    ticker_to_tenor = {v: k for k, v in curve_tickers.items()}

    df = pd.DataFrame({
        "ticker": raw["ID"],
        "rate": pd.to_numeric(raw["px"], errors="coerce")
    })
    df["tenor"] = df["ticker"].map(ticker_to_tenor)
    df["days"] = df["tenor"].map(tenor_days)
    df["date"] = cfg.valuation_date + pd.to_timedelta(df["days"], unit="D")
    df = df.dropna(subset=["rate", "days"]).sort_values("days").reset_index(drop=True)

    # Anchor short end with policy rate.
    anchor = pd.DataFrame({
        "ticker": [cfg.policy_anchor_ticker],
        "rate": [cfg.policy_rate],
        "tenor": ["ON"],
        "days": [1],
        "date": [cfg.valuation_date + pd.Timedelta(days=1)]
    })
    return pd.concat([anchor, df], ignore_index=True).sort_values("days").reset_index(drop=True)


# ============================================================
# 5. CURVE MATH
# ============================================================

def year_fraction(days, basis=360):
    return np.asarray(days, dtype=float) / basis


def zero_rate_to_discount_factor(rate_percent, days, basis=360, compounding="simple"):
    r = np.asarray(rate_percent, dtype=float) / 100.0
    t = year_fraction(days, basis)

    if compounding == "simple":
        return 1.0 / (1.0 + r * t)
    if compounding == "continuous":
        return np.exp(-r * t)
    raise ValueError("compounding must be simple or continuous")


def build_curve_functions(curve_df, cfg):
    df = curve_df.copy().sort_values("days").reset_index(drop=True)
    df = df.dropna(subset=["days", "rate"])

    # MVP approximation: treats quoted curve nodes as zero/par-ish points.
    # Desk version should align to Bloomberg bootstrapping conventions.
    df["discount_factor"] = zero_rate_to_discount_factor(
        df["rate"], df["days"], basis=cfg.day_count_basis, compounding="simple"
    )
    df["log_discount_factor"] = np.log(df["discount_factor"])

    x = df["days"].values
    y = df["log_discount_factor"].values

    if cfg.interpolation_method == "pchip":
        logdf_fn = PchipInterpolator(x, y, extrapolate=True)
    elif cfg.interpolation_method == "linear":
        logdf_fn = interp1d(x, y, fill_value="extrapolate")
    else:
        raise ValueError("interpolation_method must be 'pchip' or 'linear'")

    return df, logdf_fn


def forward_rate_from_discount_factors(logdf_fn, start_days, end_days, cfg):
    start_days = np.asarray(start_days, dtype=float)
    end_days = np.asarray(end_days, dtype=float)
    df_start = np.exp(logdf_fn(start_days))
    df_end = np.exp(logdf_fn(end_days))
    tau = (end_days - start_days) / cfg.day_count_basis
    return ((df_start / df_end - 1.0) / tau) * 100.0


# ============================================================
# 6. MARKET IMPLIED PATH
# ============================================================

def build_market_path(curve_df, meeting_dates, cfg):
    curve_with_dfs, logdf_fn = build_curve_functions(curve_df, cfg)

    meetings = pd.DataFrame({"meeting_date": pd.to_datetime(meeting_dates)})
    meetings = meetings[meetings["meeting_date"] > cfg.valuation_date].copy()
    meetings = meetings.sort_values("meeting_date").reset_index(drop=True)

    meetings["forward_start_date"] = meetings["meeting_date"] + pd.Timedelta(days=1)
    meetings["forward_end_date"] = meetings["forward_start_date"] + pd.Timedelta(days=cfg.forward_window_days)
    meetings["start_days"] = (meetings["forward_start_date"] - cfg.valuation_date).dt.days
    meetings["end_days"] = (meetings["forward_end_date"] - cfg.valuation_date).dt.days

    meetings["curve_28d_forward"] = forward_rate_from_discount_factors(
        logdf_fn, meetings["start_days"], meetings["end_days"], cfg
    )

    # Exposed basis assumption.
    meetings["implied_policy_rate"] = meetings["curve_28d_forward"] - cfg.basis_bps / 100.0

    previous_rates = [cfg.policy_rate] + meetings["implied_policy_rate"].tolist()[:-1]
    meetings["previous_implied_rate"] = previous_rates

    meetings["implied_rate_delta_bps"] = (
        meetings["implied_policy_rate"] - meetings["previous_implied_rate"]
    ) * 100.0

    meetings["number_of_25bp_moves"] = meetings["implied_rate_delta_bps"] / cfg.standard_move_bps
    meetings["pct_hike_cut"] = meetings["number_of_25bp_moves"] * 100.0

    meetings["direction"] = np.where(
        meetings["implied_rate_delta_bps"] > 0, "Hike",
        np.where(meetings["implied_rate_delta_bps"] < 0, "Cut", "No change")
    )
    return curve_with_dfs, meetings, logdf_fn


# ============================================================
# 7. SCENARIO ENGINE
# ============================================================

def build_scenario_path(market_path, cfg, scenario_moves_bps):
    df = market_path.copy()
    if len(scenario_moves_bps) != len(df):
        raise ValueError("scenario_moves_bps must have one value per meeting.")

    df["scenario_move_bps"] = scenario_moves_bps
    rate = cfg.policy_rate
    rates = []
    for move in scenario_moves_bps:
        rate += move / 100.0
        rates.append(rate)

    df["scenario_policy_rate"] = rates
    df["market_minus_scenario_bps"] = (
        df["implied_policy_rate"] - df["scenario_policy_rate"]
    ) * 100.0
    return df


def make_preset_scenario(market_path, preset):
    n = len(market_path)
    if preset == "Market":
        return market_path["implied_rate_delta_bps"].round(0).tolist()
    if preset == "Hold":
        return [0.0] * n
    if preset == "Dovish":
        base = [-25.0, -25.0, -25.0, -25.0] + [0.0] * max(0, n - 4)
        return base[:n]
    if preset == "Hawkish":
        base = [25.0, 0.0, 0.0, -25.0] + [0.0] * max(0, n - 4)
        return base[:n]
    return [0.0] * n


# ============================================================
# 8. SCENARIO FAIR VALUE / RISK
# ============================================================

def scenario_projected_rate_on_date(scenario_path, cfg, date):
    date = pd.Timestamp(date)
    past = scenario_path[scenario_path["meeting_date"] < date]
    if past.empty:
        return cfg.policy_rate
    return float(past.iloc[-1]["scenario_policy_rate"])


def scenario_discount_factor(scenario_path, cfg, maturity_days):
    start = cfg.valuation_date
    end = cfg.valuation_date + pd.Timedelta(days=int(maturity_days))
    dates = pd.date_range(start=start, end=end, freq="D")

    df = 1.0
    for d0, d1 in zip(dates[:-1], dates[1:]):
        r = scenario_projected_rate_on_date(scenario_path, cfg, d1) / 100.0
        dt = (d1 - d0).days / cfg.day_count_basis
        df /= (1.0 + r * dt)
    return df


def scenario_fair_rate(scenario_path, cfg, maturity_days):
    df = scenario_discount_factor(scenario_path, cfg, maturity_days)
    t = maturity_days / cfg.day_count_basis
    return ((1.0 / df - 1.0) / t) * 100.0


def market_rate_from_curve(logdf_fn, maturity_days, cfg):
    df = float(np.exp(logdf_fn(maturity_days)))
    t = maturity_days / cfg.day_count_basis
    return ((1.0 / df - 1.0) / t) * 100.0


def fair_value_table(scenario_path, logdf_fn, cfg, maturities, position="Long Payer", dv01_per_bp=10000):
    rows = []
    for tenor, days in maturities:
        market_rate = market_rate_from_curve(logdf_fn, days, cfg)
        scenario_rate = scenario_fair_rate(scenario_path, cfg, days)
        scenario_minus_market_bps = (scenario_rate - market_rate) * 100.0

        if position == "Long Payer":
            estimated_pnl = scenario_minus_market_bps * dv01_per_bp
        elif position == "Long Receiver":
            estimated_pnl = -scenario_minus_market_bps * dv01_per_bp
        else:
            estimated_pnl = np.nan

        trade_bias = "Pay fixed" if scenario_minus_market_bps > 0 else "Receive fixed"
        if abs(scenario_minus_market_bps) < 1:
            trade_bias = "Close to fair"

        rows.append({
            "tenor": tenor,
            "days": days,
            "market_rate": market_rate,
            "scenario_fair_rate": scenario_rate,
            "scenario_minus_market_bps": scenario_minus_market_bps,
            "trade_bias_from_scenario": trade_bias,
            "position": position,
            "dv01_per_bp": dv01_per_bp,
            "estimated_pnl": estimated_pnl
        })
    return pd.DataFrame(rows)


