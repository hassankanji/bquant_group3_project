def fetch_live_curve(curve_tickers, tenor_days):
    securities = list(curve_tickers.values())

    req = bql.Request(
        securities,
        {
            "px": bq.data.px_last()
        }
    )

    df_raw = bq.execute(req)[0].df().reset_index()

    # Standardize columns from BQL output
    # Usually has: ID, DATE, CURRENCY, px
    id_col = "ID"
    px_col = "px"

    ticker_to_tenor = {v: k for k, v in curve_tickers.items()}

    df = pd.DataFrame({
        "ticker": df_raw[id_col],
        "rate": pd.to_numeric(df_raw[px_col], errors="coerce")
    })

    df["tenor"] = df["ticker"].map(ticker_to_tenor)
    df["days"] = df["tenor"].map(tenor_days)
    df["date"] = config.valuation_date + pd.to_timedelta(df["days"], unit="D")
    df = df.dropna(subset=["rate", "days"]).sort_values("days").reset_index(drop=True)

    # Add ON anchor at policy rate to stabilize short-end interpolation
    anchor = pd.DataFrame({
        "ticker": ["MXONBR Index / policy anchor"],
        "rate": [config.policy_rate],
        "tenor": ["ON"],
        "days": [1],
        "date": [config.valuation_date + pd.Timedelta(days=1)]
    })

    df = pd.concat([anchor, df], ignore_index=True).sort_values("days").reset_index(drop=True)
    return df


