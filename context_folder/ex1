def make_research_summary(market_path, scenario_path, fv):
    total_market_bps = (market_path["implied_policy_rate"].iloc[-1] - market_path["implied_policy_rate"].iloc[0]) * 100
    total_scenario_bps = (scenario_path["scenario_policy_rate"].iloc[-1] - scenario_path["scenario_policy_rate"].iloc[0]) * 100
    biggest = fv.iloc[fv["scenario_minus_market_bps"].abs().argmax()]
    return pd.DataFrame({
        "Research Question": [
            "What is the market pricing?",
            "What does my scenario imply?",
            "Where is the largest gap?"
        ],
        "Answer": [
            f"Market path changes by {total_market_bps:.1f} bp across displayed meetings.",
            f"Scenario path changes by {total_scenario_bps:.1f} bp across displayed meetings.",
            f"{biggest['tenor']} differs by {biggest['scenario_minus_market_bps']:.1f} bp vs market."
        ]
    })


def make_sales_summary(market_path, scenario_path, fv):
    best = fv.iloc[fv["scenario_minus_market_bps"].abs().argmax()]
    return pd.DataFrame({
        "Client Talking Point": [
            "Market-implied path",
            "House/user scenario",
            "Most affected tenor"
        ],
        "Message": [
            "The live curve is translated into meeting-by-meeting Banxico pricing.",
            "Users can replace the market path with a specific policy sequence.",
            f"{best['tenor']} has the largest scenario gap: {best['scenario_minus_market_bps']:.1f} bp."
        ]
    })


def make_trading_summary(fv, position):
    rows = []
    for _, row in fv.iterrows():
        rows.append({
            "Tenor": row["tenor"],
            "Scenario Gap (bp)": row["scenario_minus_market_bps"],
            "Trade Bias": row["trade_bias_from_scenario"],
            f"Estimated P&L for {position}": row["estimated_pnl"],
        })
    return pd.DataFrame(rows)


