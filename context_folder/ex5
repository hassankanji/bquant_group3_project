def safe_float(x, default=np.nan):
    try:
        return float(x)
    except Exception:
        return default


def _flatten_bql_df(response_item):
    df = response_item.df().copy()
    df = df.reset_index()

    possible_id_cols = ["ID", "index", "security", "Security"]
    id_col = None

    for col in possible_id_cols:
        if col in df.columns:
            id_col = col
            break

    if id_col is None:
        id_col = df.columns[0]

    df = df.rename(columns={id_col: "ID"})
    df = df.loc[:, ~df.columns.duplicated()]
    return df


def _find_col(df, candidates):
    lower_map = {str(c).lower(): c for c in df.columns}

    for candidate in candidates:
        if candidate.lower() in lower_map:
            return lower_map[candidate.lower()]

    for col in df.columns:
        col_lower = str(col).lower()
        for candidate in candidates:
            if candidate.lower() in col_lower:
                return col

    return None


def _first_numeric_col(df, exclude_cols=None):
    if exclude_cols is None:
        exclude_cols = []

    exclude_set = set([str(x).lower() for x in exclude_cols])

    for col in df.columns:
        if str(col).lower() in exclude_set:
            continue

        s = pd.to_numeric(df[col], errors="coerce")

        if s.notna().any():
            return col

    return None


def to_date(x):
    if isinstance(x, pd.Timestamp):
        return x.date()
    if isinstance(x, dt.datetime):
        return x.date()
    return x


def actual_days(start, end):
    start = to_date(start)
    end = to_date(end)
    return (end - start).days


def date_to_ordinal(d):
    d = to_date(d)
    return pd.Timestamp(d).toordinal()


def ordinal_to_timestamp(x):
    return pd.Timestamp.fromordinal(int(round(float(x))))


# =========================
# RATE / DF MATH
# =========================
def daily_log_from_annual_pct(rate_pct, basis=360):
    if pd.isna(rate_pct):
        return np.nan

    r = rate_pct / 100.0
    daily_factor = 1.0 + r / float(basis)

    if daily_factor <= 0:
        return np.nan

    return np.log(daily_factor)


def annual_pct_from_daily_log(daily_log_rate, basis=360):
    if pd.isna(daily_log_rate):
        return np.nan

    daily_simple = np.expm1(daily_log_rate)
    annual_decimal = daily_simple * float(basis)
    return annual_decimal * 100.0


def bullet_discount_factor_from_par_rate(rate_pct, tenor_days, basis=360):
    """
    Short-end bullet/par approximation:
        DF(T) = 1 / (1 + S * alpha)

    This is appropriate for short-end OIS-style tenors where the fixed leg is
    effectively one maturity payment.
    """
    if pd.isna(rate_pct) or tenor_days <= 0:
        return np.nan

    r = rate_pct / 100.0
    alpha = tenor_days / float(basis)

    denom = 1.0 + r * alpha

    if denom <= 0:
        return np.nan

    return 1.0 / denom


def logdf_from_par_rate(rate_pct, tenor_days, basis=360):
    df = bullet_discount_factor_from_par_rate(
        rate_pct=rate_pct,
        tenor_days=tenor_days,
        basis=basis
    )

    if not np.isfinite(df) or df <= 0:
        return np.nan

    return np.log(df)


def log_accumulation_from_logdf(logdf):
    """
    Accumulation factor is 1 / DF. Therefore:
        log_accumulation = -log_discount_factor
    """
    if pd.isna(logdf):
        return np.nan
    return -float(logdf)


def par_rate_from_discount_factor(df, tenor_days, basis=360):
    """
    Inverts short-end bullet relationship:
        S = (1 / DF - 1) / alpha
    """
    if pd.isna(df) or df <= 0 or tenor_days <= 0:
        return np.nan

    alpha = tenor_days / float(basis)
    rate_decimal = (1.0 / df - 1.0) / alpha
    return rate_decimal * 100.0


def par_rate_from_logdf(logdf, tenor_days, basis=360):
    if pd.isna(logdf) or tenor_days <= 0:
        return np.nan

    df = np.exp(float(logdf))
    return par_rate_from_discount_factor(df, tenor_days, basis=basis)


def annual_pct_from_log_accumulation(log_factor, tenor_days, basis=360):
    """
    Equivalent annualized bullet/simple rate from log accumulation.
    """
    if pd.isna(log_factor) or tenor_days <= 0:
        return np.nan

    df = np.exp(-float(log_factor))
    return par_rate_from_discount_factor(df, tenor_days, basis=basis)


def no_change_zero_rate_to_date(
    valuation_date,
    maturity_date,
    current_on_rate_pct,
    basis=360
):
    valuation_date = to_date(valuation_date)
    maturity_date = to_date(maturity_date)

    tenor_days = actual_days(valuation_date, maturity_date)

    if tenor_days <= 0:
        return current_on_rate_pct

    current_daily_log = daily_log_from_annual_pct(
        current_on_rate_pct,
        basis=basis
    )

    if not np.isfinite(current_daily_log):
        return np.nan

    log_accumulation = current_daily_log * tenor_days

    return annual_pct_from_log_accumulation(
        log_factor=log_accumulation,
        tenor_days=tenor_days,
        basis=basis
    )


