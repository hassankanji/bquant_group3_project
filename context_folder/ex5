def get_central_bank_meetings_bql(country_name, start, end, verbose=False):
    cfg = COUNTRY_MAP[country_name]
    universe = cfg["country_universe"]

    include_keywords = [x.lower() for x in cfg["include_event_keywords"]]
    exclude_keywords = [x.lower() for x in cfg["exclude_event_keywords"]]
    ticker_root = cfg["rate_decision_ticker_root"].lower()

    start = to_date(start)
    end = to_date(end)

    data_item = bq.data.calendar(
        type="CENTRAL_BANKS",
        subtype="ALL_CENTRAL_BANKS",
        dates=bq.func.range(start.strftime("%Y-%m-%d"), end.strftime("%Y-%m-%d")),
        view="EXTENDED"
    )

    request = bql.Request(universe, data_item)
    response = bq.execute(request)

    cal_df = _flatten_bql_df(response[0])

    if verbose:
        display(cal_df)

    if cal_df.empty:
        raise ValueError("BQL central bank calendar returned no rows.")

    release_date_col = _find_col(
        cal_df,
        ["RELEASE_DATE", "release_date", "Release Date", "RELEASE_DATE_TIME", "release_date_time"]
    )

    event_name_col = _find_col(
        cal_df,
        ["EVENT_NAME", "event_name", "Event Name"]
    )

    release_time_col = _find_col(
        cal_df,
        ["RELEASE_TIME", "release_time", "Release Time"]
    )

    value_col = _find_col(
        cal_df,
        ["VALUE", "value", "calendar"]
    )

    if release_date_col is None:
        raise ValueError(f"Could not find release date column. Columns: {list(cal_df.columns)}")

    if event_name_col is None:
        raise ValueError(f"Could not find event name column. Columns: {list(cal_df.columns)}")

    df = cal_df.copy()

    df["Meeting Date"] = pd.to_datetime(df[release_date_col], errors="coerce").dt.date
    df["Event Name"] = df[event_name_col].astype(str)

    if release_time_col is not None:
        df["Release Time"] = df[release_time_col].astype(str)
    else:
        df["Release Time"] = ""

    if value_col is not None:
        df["Ticker"] = df[value_col].astype(str)
    else:
        df["Ticker"] = ""

    df = df.dropna(subset=["Meeting Date"]).copy()

    event_lower = df["Event Name"].str.lower()
    ticker_lower = df["Ticker"].str.lower()

    include_mask = (
        event_lower.apply(lambda x: any(k in x for k in include_keywords)) |
        ticker_lower.str.contains(ticker_root, na=False)
    )

    exclude_mask = event_lower.apply(lambda x: any(k in x for k in exclude_keywords))

    df = df[include_mask & ~exclude_mask].copy()

    if df.empty:
        raise ValueError(
            "No rate-decision events found after filtering calendar. "
            "Check event keywords/ticker mapping."
        )

    grouped = (
        df.groupby("Meeting Date")
        .agg({
            "Event Name": lambda x: " | ".join(sorted(set([str(v) for v in x]))),
            "Release Time": lambda x: " | ".join(sorted(set([str(v) for v in x if str(v) != "nan"]))),
            "Ticker": lambda x: " | ".join(sorted(set([str(v) for v in x if str(v) != "nan"])))
        })
        .reset_index()
    )

    grouped["Type"] = "BQL Central Bank Calendar"
    grouped = grouped.sort_values("Meeting Date").reset_index(drop=True)

    return grouped


def estimate_next_boundary_date(requested_df, country_name):
    cfg = COUNTRY_MAP[country_name]
    fallback_gap = int(cfg.get("fallback_meeting_gap_days", 42))

    dates = requested_df["Meeting Date"].sort_values().tolist()

    if len(dates) >= 2:
        gaps = [
            actual_days(dates[i], dates[i + 1])
            for i in range(len(dates) - 1)
        ]

        gaps = [g for g in gaps if g > 10]

        if len(gaps) > 0:
            gap = int(round(np.median(gaps)))
        else:
            gap = fallback_gap
    else:
        gap = fallback_gap

    return dates[-1] + dt.timedelta(days=gap)


def build_meeting_calendar_for_model(
    country_name,
    effective_lag_days=0,
    boundary_lookahead_days=800
):
    today = dt.date.today()
    year_end = dt.date(today.year, 12, 31)
    pull_end = year_end + dt.timedelta(days=int(boundary_lookahead_days))

    meetings_df = get_central_bank_meetings_bql(
        country_name=country_name,
        start=today,
        end=pull_end,
        verbose=False
    )

    meetings_df["Meeting Date"] = meetings_df["Meeting Date"].apply(to_date)
    meetings_df = meetings_df[meetings_df["Meeting Date"] >= today].copy()
    meetings_df = meetings_df.sort_values("Meeting Date").reset_index(drop=True)

    requested_df = meetings_df[meetings_df["Meeting Date"] <= year_end].copy()
    boundary_candidates = meetings_df[meetings_df["Meeting Date"] > year_end].copy()

    if requested_df.empty:
        raise ValueError(f"No future rate-decision meetings found through year-end {year_end}.")

    requested_df["Requested"] = True
    requested_df["Boundary Only"] = False
    requested_df["Boundary Source"] = ""

    if not boundary_candidates.empty:
        boundary_df = boundary_candidates.iloc[[0]].copy()
        boundary_df["Boundary Source"] = "BQL next rate decision"
    else:
        estimated_boundary_date = estimate_next_boundary_date(requested_df, country_name)

        boundary_df = pd.DataFrame({
            "Meeting Date": [estimated_boundary_date],
            "Event Name": ["Estimated boundary only"],
            "Release Time": [""],
            "Ticker": [""],
            "Type": ["Estimated Boundary"],
            "Boundary Source": ["Estimated from recent meeting cadence"]
        })

    boundary_df["Requested"] = False
    boundary_df["Boundary Only"] = True

    model_df = pd.concat([requested_df, boundary_df], ignore_index=True)
    model_df = model_df.sort_values("Meeting Date").reset_index(drop=True)

    model_df["Effective Date"] = model_df["Meeting Date"].apply(
        lambda x: x + dt.timedelta(days=int(effective_lag_days))
    )

    return model_df, today, year_end


# =========================
# INTERPOLATION ENGINE FOR MEETINGS
# =========================
def interpolation_weight(t, method="Linear", shape=2.0):
    if pd.isna(t):
        return np.nan

    t = max(0.0, min(1.0, float(t)))
    method = str(method)

    shape = safe_float(shape, 2.0)

    if not np.isfinite(shape) or shape <= 0:
        shape = 2.0

    if method == "Linear":
        return t

    if method == "Front-loaded":
        return 1.0 - (1.0 - t) ** shape

    if method == "Back-loaded":
        return t ** shape

    if method == "Smoothstep":
        return 3.0 * t ** 2 - 2.0 * t ** 3

    if method == "Jump then flat":
        return 1.0 if t > 0 else 0.0

    if method == "Flat then jump":
        return 0.0 if t < 1.0 else 1.0

    return t


def interpolated_level(start_rate, end_rate, t, method="Linear", shape=2.0):
    start_rate = float(start_rate)
    end_rate = float(end_rate)

    t = max(0.0, min(1.0, float(t)))
    method = str(method)

    if method == "Exponential":
        if start_rate > 0 and end_rate > 0:
            return start_rate * (end_rate / start_rate) ** t
        else:
            return start_rate + t * (end_rate - start_rate)

    w = interpolation_weight(t, method=method, shape=shape)
    return start_rate + w * (end_rate - start_rate)


def interval_avg_daily_log_from_meeting_rates(
    interval_start,
    interval_end,
    start_rate_pct,
    meeting_dates,
    meeting_post_rates,
    basis=360
):
    interval_start = to_date(interval_start)
    interval_end = to_date(interval_end)

    total_days = actual_days(interval_start, interval_end)

    if total_days <= 0:
        return np.nan

    meeting_pairs = []

    for d, r in zip(meeting_dates, meeting_post_rates):
        d = to_date(d)

        if interval_start < d < interval_end:
            meeting_pairs.append((d, float(r)))

    meeting_pairs = sorted(meeting_pairs, key=lambda x: x[0])

    segments = []
    seg_start = interval_start
    seg_rate = float(start_rate_pct)

    for meeting_date, post_rate in meeting_pairs:
        days = actual_days(seg_start, meeting_date)

        if days > 0:
            segments.append((days, seg_rate))

        seg_start = meeting_date
        seg_rate = post_rate

    final_days = actual_days(seg_start, interval_end)

    if final_days > 0:
        segments.append((final_days, seg_rate))

    log_sum = 0.0

    for days, rate in segments:
        dl = daily_log_from_annual_pct(rate, basis=basis)

        if not np.isfinite(dl):
            return np.nan

        log_sum += dl * days

    return log_sum / total_days


def solve_scalar_bisection(func, x0, lower=None, upper=None, max_iter=100, tol=1e-12):
    x0 = float(x0)

    if lower is None or upper is None:
        width = 1.0
        center = x0 if np.isfinite(x0) else 0.0

        lower = center - width
        upper = center + width

        f_lower = func(lower)
        f_upper = func(upper)

        expand_count = 0

        while np.isfinite(f_lower) and np.isfinite(f_upper) and f_lower * f_upper > 0 and expand_count < 60:
            width *= 2.0
            lower = center - width
            upper = center + width
            f_lower = func(lower)
            f_upper = func(upper)
            expand_count += 1
    else:
        lower = float(lower)
        upper = float(upper)
        f_lower = func(lower)
        f_upper = func(upper)

    f_lower = func(lower)
    f_upper = func(upper)

    if not np.isfinite(f_lower) or not np.isfinite(f_upper):
        raise ValueError("Scalar solver encountered non-finite bracket values.")

    if abs(f_lower) < tol:
        return lower

    if abs(f_upper) < tol:
        return upper

    if f_lower * f_upper > 0:
        grid = np.linspace(lower, upper, 2001)
        vals = np.array([func(x) for x in grid], dtype=float)
        valid = np.isfinite(vals)

        if not valid.any():
            raise ValueError("Scalar solver could not find any finite function values.")

        idx = np.nanargmin(np.abs(vals))
        return float(grid[idx])

    for _ in range(max_iter):
        mid = 0.5 * (lower + upper)
        f_mid = func(mid)

        if not np.isfinite(f_mid):
            raise ValueError("Scalar solver encountered non-finite midpoint value.")

        if abs(f_mid) < tol:
            return mid

        if f_lower * f_mid <= 0:
            upper = mid
            f_upper = f_mid
        else:
            lower = mid
            f_lower = f_mid

    return 0.5 * (lower + upper)


def solve_single_meeting_rate_for_interval(
    interval_start,
    interval_end,
    meeting_date,
    start_rate_pct,
    target_avg_daily_log,
    basis=360
):
    interval_start = to_date(interval_start)
    interval_end = to_date(interval_end)
    meeting_date = to_date(meeting_date)

    d0 = actual_days(interval_start, meeting_date)
    d1 = actual_days(meeting_date, interval_end)
    total_days = actual_days(interval_start, interval_end)

    if total_days <= 0 or d1 <= 0:
        return np.nan

    start_daily_log = daily_log_from_annual_pct(start_rate_pct, basis=basis)

    solved_daily_log = (
        target_avg_daily_log * total_days - start_daily_log * d0
    ) / d1

    return annual_pct_from_daily_log(solved_daily_log, basis=basis)


def solve_multi_meeting_rates_for_interval(
    interval_start,
    interval_end,
    start_rate_pct,
    meeting_dates,
    target_avg_daily_log,
    method="Linear",
    shape=2.0,
    basis=360
):
    interval_start = to_date(interval_start)
    interval_end = to_date(interval_end)

    total_days = actual_days(interval_start, interval_end)

    if total_days <= 0:
        return [np.nan for _ in meeting_dates], np.nan

    valid_meetings = [
        to_date(d)
        for d in meeting_dates
        if interval_start < to_date(d) < interval_end
    ]

    valid_meetings = sorted(valid_meetings)

    if len(valid_meetings) == 0:
        return [], start_rate_pct

    fwd_rate_guess = annual_pct_from_daily_log(target_avg_daily_log, basis=basis)

    def meeting_rates_from_terminal(end_rate):
        rates = []

        for d in valid_meetings:
            t = actual_days(interval_start, d) / float(total_days)
            r = interpolated_level(
                start_rate=start_rate_pct,
                end_rate=end_rate,
                t=t,
                method=method,
                shape=shape
            )
            rates.append(r)

        return rates

    def objective(end_rate):
        rates = meeting_rates_from_terminal(end_rate)

        avg_log = interval_avg_daily_log_from_meeting_rates(
            interval_start=interval_start,
            interval_end=interval_end,
            start_rate_pct=start_rate_pct,
            meeting_dates=valid_meetings,
            meeting_post_rates=rates,
            basis=basis
        )

        return avg_log - target_avg_daily_log

    terminal_rate = solve_scalar_bisection(
        func=objective,
        x0=fwd_rate_guess
    )

    solved_rates = meeting_rates_from_terminal(terminal_rate)

    return solved_rates, terminal_rate


# =========================
# MEETING SOLVER — V2 LOG-DF HYBRID
# =========================
def solve_meeting_levels_logdf_hybrid(
    df_curve,
    logdf_fn,
    model_meetings_df,
    current_on_rate_pct,
    step_size_pct,
    basis=360,
    interpolation_method="Linear",
    interpolation_shape=2.0,
    min_days_to_next_tenor=10
):
    """
    Hybrid V2 solver.

    Uses the smooth market log-discount-factor curve as the source of truth:
        market_log_accumulation(T) = -market_log_discount_factor(T)

    Then solves a meeting-step O/N path that reproduces that market accumulation.
    """
    valuation_date = df_curve.attrs.get("valuation_date", dt.date.today())
    valuation_date = to_date(valuation_date)

    curve_nodes = df_curve.copy().sort_values("maturity").reset_index(drop=True)
    curve_nodes["maturity_date"] = pd.to_datetime(curve_nodes["maturity"]).dt.date

    curve_nodes = curve_nodes[
        curve_nodes["maturity_date"] > valuation_date
    ].copy()

    if curve_nodes.empty:
        raise ValueError("No valid TIIE RFR curve nodes after valuation date.")

    meetings_df = model_meetings_df.copy()
    meetings_df["Meeting Date"] = meetings_df["Meeting Date"].apply(to_date)
    meetings_df["Effective Date"] = meetings_df["Effective Date"].apply(to_date)

    meetings_df = meetings_df[
        meetings_df["Effective Date"].apply(lambda x: actual_days(valuation_date, x) > 0)
    ].copy()

    requested_df = meetings_df[meetings_df["Requested"] == True].copy()
    requested_df = requested_df.sort_values("Effective Date").reset_index(drop=True)

    boundary_df = meetings_df[meetings_df["Boundary Only"] == True].copy()
    boundary_df = boundary_df.sort_values("Effective Date").reset_index(drop=True)

    if requested_df.empty:
        raise ValueError("No requested meetings available after valuation date.")

    meeting_rows = []
    instrument_fit_rows = []
    bucket_rows = []

    previous_rate = float(current_on_rate_pct)
    solved_effective_dates = set()
    solve_start_date = valuation_date

    for _, inst in curve_nodes.iterrows():
        maturity_date = inst["maturity_date"]
        tenor_days = actual_days(valuation_date, maturity_date)

        if tenor_days <= 0:
            continue

        market_rate = float(inst["rate"])

        market_logdf = logdf_at_days(logdf_fn, tenor_days)
        target_total_log_factor = -market_logdf

        no_change_rate_to_tenor = no_change_zero_rate_to_date(
            valuation_date=valuation_date,
            maturity_date=maturity_date,
            current_on_rate_pct=current_on_rate_pct,
            basis=basis
        )

        curve_market_rate_from_logdf = market_par_rate_from_logdf_fn(
            logdf_fn=logdf_fn,
            days=tenor_days,
            basis=basis
        )

        market_vs_no_change_bp = (
            curve_market_rate_from_logdf - no_change_rate_to_tenor
        ) * 100.0 if np.isfinite(no_change_rate_to_tenor) else np.nan

        if not np.isfinite(target_total_log_factor):
            continue

        candidates = requested_df[
            (~requested_df["Effective Date"].isin(solved_effective_dates)) &
            (requested_df["Effective Date"] > solve_start_date) &
            (requested_df["Effective Date"] < maturity_date)
        ].copy()

        candidates["Days to Tenor"] = candidates["Effective Date"].apply(
            lambda x: actual_days(x, maturity_date)
        )

        candidates = candidates.sort_values("Effective Date").reset_index(drop=True)

        if candidates.empty:
            bucket_rows.append({
                "Curve Bucket": inst["ID"],
                "Tenor Date": maturity_date,
                "Market Rate (%)": curve_market_rate_from_logdf,
                "Meetings Solved in Bucket": 0,
                "Reason": "No unsolved meetings between solve start and tenor",
                "Min Days to Tenor": int(min_days_to_next_tenor)
            })
            continue

        too_close_mask = candidates["Days to Tenor"] < int(min_days_to_next_tenor)

        if too_close_mask.any():
            bucket_rows.append({
                "Curve Bucket": inst["ID"],
                "Tenor Date": maturity_date,
                "Market Rate (%)": curve_market_rate_from_logdf,
                "Meetings Solved in Bucket": 0,
                "Reason": "Skipped tenor because at least one unsolved meeting is too close to this tenor",
                "Closest Meeting": candidates.loc[too_close_mask, "Effective Date"].min(),
                "Min Actual Days to Tenor": candidates["Days to Tenor"].min(),
                "Min Days to Tenor": int(min_days_to_next_tenor)
            })
            continue

        eligible = candidates.copy()

        known_log_to_start = model_log_factor_to_date(
            valuation_date=valuation_date,
            maturity_date=solve_start_date,
            current_on_rate_pct=current_on_rate_pct,
            meeting_table=pd.DataFrame(meeting_rows),
            basis=basis
        )

        remaining_days = actual_days(solve_start_date, maturity_date)

        if remaining_days <= 0:
            continue

        target_remaining_avg_daily_log = (
            target_total_log_factor - known_log_to_start
        ) / remaining_days

        effective_dates = eligible["Effective Date"].tolist()

        if len(effective_dates) == 1:
            solved_rate = solve_single_meeting_rate_for_interval(
                interval_start=solve_start_date,
                interval_end=maturity_date,
                meeting_date=effective_dates[0],
                start_rate_pct=previous_rate,
                target_avg_daily_log=target_remaining_avg_daily_log,
                basis=basis
            )

            solved_rates = [solved_rate]
            solved_terminal_rate = solved_rate
            allocation_method_used = "Exact single-meeting log-DF cumulative solve"

        else:
            solved_rates, solved_terminal_rate = solve_multi_meeting_rates_for_interval(
                interval_start=solve_start_date,
                interval_end=maturity_date,
                start_rate_pct=previous_rate,
                meeting_dates=effective_dates,
                target_avg_daily_log=target_remaining_avg_daily_log,
                method=interpolation_method,
                shape=interpolation_shape,
                basis=basis
            )

            allocation_method_used = f"{interpolation_method} log-DF cumulative interpolation"

        pre_rate = previous_rate

        for k, (_, mtg) in enumerate(eligible.iterrows()):
            meeting_date = mtg["Meeting Date"]
            effective_date = mtg["Effective Date"]
            post_rate = float(solved_rates[k])

            if k + 1 < len(eligible):
                segment_end = eligible.loc[k + 1, "Effective Date"]
            else:
                segment_end = maturity_date

            expected_move = post_rate - pre_rate if np.isfinite(post_rate) else np.nan
            expected_move_bp = expected_move * 100.0 if np.isfinite(expected_move) else np.nan

            expected_steps, whole_steps, probability = decompose_hike_probability(
                expected_move_pct=expected_move,
                step_size_pct=step_size_pct
            )

            total_bucket_days = actual_days(solve_start_date, maturity_date)

            if total_bucket_days > 0:
                t_in_bucket = actual_days(solve_start_date, effective_date) / float(total_bucket_days)
            else:
                t_in_bucket = np.nan

            meeting_rows.append({
                "Meeting": meeting_date,
                "Effective Date": effective_date,
                "Segment End": segment_end,
                "Curve Interval Start": solve_start_date,
                "Curve Interval End": maturity_date,
                "Curve Instrument": inst["ID"],
                "Curve Instrument Rate (%)": curve_market_rate_from_logdf,
                "Raw Quote Rate (%)": market_rate,
                "Market Log DF": market_logdf,
                "Market DF": np.exp(market_logdf),
                "Forward Avg Rate (%)": annual_pct_from_daily_log(
                    target_remaining_avg_daily_log,
                    basis=basis
                ),
                "Interpolation Method": allocation_method_used,
                "Interpolation t": t_in_bucket,
                "Days to Tenor": actual_days(effective_date, maturity_date),
                "Pre-Meeting O/N (%)": pre_rate,
                "Post-Meeting O/N (%)": post_rate,
                "Cumulative Move (%)": post_rate - current_on_rate_pct if np.isfinite(post_rate) else np.nan,
                "Cumulative Move (bp)": (post_rate - current_on_rate_pct) * 100.0 if np.isfinite(post_rate) else np.nan,
                "Expected Move (%)": expected_move,
                "Expected Move (bp)": expected_move_bp,
                "Expected Steps": expected_steps,
                "# Steps": whole_steps,
                "% of Step": probability,
                "No-Change Rate to Tenor (%)": no_change_rate_to_tenor,
                "Market vs No-Change (bp)": market_vs_no_change_bp
            })

            solved_effective_dates.add(effective_date)
            pre_rate = post_rate
            previous_rate = post_rate

        bucket_rows.append({
            "Curve Bucket": inst["ID"],
            "Tenor Date": maturity_date,
            "Raw Quote Rate (%)": market_rate,
            "Market Rate from Log DF (%)": curve_market_rate_from_logdf,
            "Market DF": np.exp(market_logdf),
            "Market Log DF": market_logdf,
            "Meetings Solved in Bucket": len(eligible),
            "Allocation Method": allocation_method_used,
            "Solved Terminal Rate (%)": solved_terminal_rate,
            "Solve Start Date": solve_start_date,
            "Target Remaining Avg Rate (%)": annual_pct_from_daily_log(
                target_remaining_avg_daily_log,
                basis=basis
            ),
            "Min Days to Tenor": int(min_days_to_next_tenor)
        })

        solve_start_date = maturity_date

        if len(solved_effective_dates) >= len(requested_df):
            break

    meeting_table = pd.DataFrame(meeting_rows)

    if meeting_table.empty:
        raise ValueError(
            "No meeting path could be solved. Try lowering the minimum days-to-tenor input "
            "or extending the curve horizon."
        )

    meeting_table = meeting_table.sort_values("Effective Date").reset_index(drop=True)

    chart_end_date = get_chart_end_date(
        meeting_table=meeting_table,
        model_meetings_df=model_meetings_df,
        curve_df=df_curve,
        buffer_days=30
    )

    fit_curve_nodes = curve_nodes[
        curve_nodes["maturity_date"] <= chart_end_date
    ].copy()

    if fit_curve_nodes.empty:
        fit_curve_nodes = curve_nodes.head(1).copy()

    for _, inst in fit_curve_nodes.iterrows():
        maturity_date = inst["maturity_date"]
        tenor_days = actual_days(valuation_date, maturity_date)

        if tenor_days <= 0:
            continue

        market_rate_from_logdf = market_par_rate_from_logdf_fn(
            logdf_fn=logdf_fn,
            days=tenor_days,
            basis=basis
        )

        rebuilt_rate = model_rebuilt_par_rate_to_date(
            valuation_date=valuation_date,
            maturity_date=maturity_date,
            current_on_rate_pct=current_on_rate_pct,
            meeting_table=meeting_table,
            basis=basis
        )

        if np.isfinite(rebuilt_rate):
            rate_error_bp = (market_rate_from_logdf - rebuilt_rate) * 100.0
        else:
            rate_error_bp = np.nan

        instrument_fit_rows.append({
            "Instrument": inst["ID"],
            "Instrument Maturity": maturity_date,
            "Tenor Days": tenor_days,
            "Raw Quote Rate (%)": float(inst["rate"]),
            "Market Rate from Log DF (%)": market_rate_from_logdf,
            "Model-Rebuilt Rate (%)": rebuilt_rate,
            "Rate Error (bp)": rate_error_bp,
            "Used In Fit": True
        })

    instrument_fit_table = pd.DataFrame(instrument_fit_rows)
    interval_allocation_table = pd.DataFrame(bucket_rows)

    diagnostics = {
        "Number of Instruments Used": int(len(curve_nodes)),
        "Number of Meetings Solved": int(len(meeting_table)),
        "Boundary Meeting Date": boundary_df["Meeting Date"].iloc[0] if not boundary_df.empty else "",
        "Boundary Effective Date": boundary_df["Effective Date"].iloc[0] if not boundary_df.empty else "",
        "Boundary Source": boundary_df["Boundary Source"].iloc[0] if not boundary_df.empty and "Boundary Source" in boundary_df.columns else "",
        "Basis": basis,
        "Min Days to Next Tenor": int(min_days_to_next_tenor),
        "Interpolation Method": interpolation_method,
        "Interpolation Shape": interpolation_shape,
        "Chart End Date": chart_end_date,
        "Solver": "V2 log-DF curve solve with meeting roll-forward threshold",
        "Curve Construction": "Par/bullet quote -> discount factor -> log DF interpolation",
        "Curve Side": df_curve.attrs.get("curve_side", ""),
        "Interval Allocation Table": interval_allocation_table,
        "Market Matrix Rank": np.nan,
        "Singular Values": np.array([]),
        "Condition Number": np.nan,
        "Residual Sum of Squares": np.nan
    }

    return meeting_table, instrument_fit_table, diagnostics


# =========================
# SOLVER HELPERS
# =========================
def decompose_hike_probability(expected_move_pct, step_size_pct):
    if step_size_pct == 0 or pd.isna(expected_move_pct):
        return np.nan, np.nan, np.nan

    expected_steps = expected_move_pct / step_size_pct

    sign = np.sign(expected_steps)
    abs_steps = abs(expected_steps)

    whole_steps = int(np.floor(abs_steps))
    probability = (abs_steps - whole_steps) * 100.0

    return expected_steps, int(sign * whole_steps), sign * probability


