def get_curve_data(curve_name, curve_side="MID", basis=360, verbose=False):
    if curve_name not in CURVE_MAP:
        raise ValueError(
            f"Unknown curve name: {curve_name}. "
            f"Valid curve choices are: {list(CURVE_MAP.keys())}"
        )

    curve_side = str(curve_side).upper()

    if curve_side not in ["MID", "BID", "ASK"]:
        raise ValueError("curve_side must be one of: MID, BID, ASK")

    curve_ticker = CURVE_MAP[curve_name]
    universe = bq.univ.curvemembers(symbols=curve_ticker)

    request = bql.Request(
        universe,
        {"Curve Rate": bq.data.curve_rate(side=curve_side)}
    )

    response = bq.execute(request)
    members_df = _flatten_bql_df(response[0])

    if verbose:
        display(members_df.head(40))

    rate_col = _find_col(members_df, ["Curve Rate", "curve_rate", "rate"])
    date_col = _find_col(members_df, ["DATE", "date"])

    if rate_col is None:
        raise ValueError(f"Could not find Curve Rate column. Columns: {list(members_df.columns)}")

    keep_cols = ["ID", rate_col]

    if date_col is not None:
        keep_cols.append(date_col)

    members_df = members_df[keep_cols].copy()
    members_df = members_df.rename(columns={rate_col: "rate"})

    if date_col is not None:
        members_df = members_df.rename(columns={date_col: "curve_date"})
    else:
        members_df["curve_date"] = pd.Timestamp(dt.date.today())

    members_df["rate"] = pd.to_numeric(members_df["rate"], errors="coerce")
    members_df["curve_date"] = pd.to_datetime(members_df["curve_date"], errors="coerce")

    members_df = members_df.dropna(subset=["ID", "rate"])
    members_df = members_df[(members_df["rate"] > -50) & (members_df["rate"] < 100)]

    if members_df.empty:
        raise ValueError("No valid curve members/rates returned.")

    front_rate_anchor = float(members_df["rate"].iloc[0])

    if members_df["curve_date"].notna().any():
        valuation_date = members_df["curve_date"].dropna().iloc[0].date()
    else:
        valuation_date = dt.date.today()

    ids = members_df["ID"].dropna().astype(str).unique().tolist()

    maturity_request = bql.Request(
        ids,
        {"Maturity": bq.data.maturity()}
    )

    maturity_response = bq.execute(maturity_request)
    maturity_df = _flatten_bql_df(maturity_response[0])

    maturity_col = _find_col(maturity_df, ["Maturity", "maturity"])

    if maturity_col is None:
        raise ValueError(f"Could not find Maturity column. Columns: {list(maturity_df.columns)}")

    maturity_df = maturity_df[["ID", maturity_col]].copy()
    maturity_df = maturity_df.rename(columns={maturity_col: "maturity"})
    maturity_df["maturity"] = pd.to_datetime(maturity_df["maturity"], errors="coerce")

    curve_df = pd.merge(
        members_df,
        maturity_df,
        on="ID",
        how="left"
    )

    curve_df = curve_df.dropna(subset=["maturity", "rate"]).copy()
    curve_df["valuation_date"] = pd.Timestamp(valuation_date)

    curve_df["days_to_maturity"] = curve_df["maturity"].apply(
        lambda x: actual_days(valuation_date, x.date())
    )

    curve_df = curve_df[curve_df["days_to_maturity"] > 0].copy()

    curve_df["T_360"] = curve_df["days_to_maturity"] / 360.0
    curve_df["T_365"] = curve_df["days_to_maturity"] / 365.0

    curve_df = curve_df.sort_values("maturity")
    curve_df = curve_df.drop_duplicates(subset=["maturity"], keep="first")
    curve_df = curve_df.reset_index(drop=True)

    if curve_df.empty:
        raise ValueError("Curve dataframe is empty after maturity filtering.")

    curve_df.attrs["valuation_date"] = valuation_date
    curve_df.attrs["front_rate_anchor"] = front_rate_anchor
    curve_df.attrs["curve_ticker"] = curve_ticker
    curve_df.attrs["curve_name"] = curve_name
    curve_df.attrs["curve_side"] = curve_side
    curve_df.attrs["basis"] = basis

    return curve_df


