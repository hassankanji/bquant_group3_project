        "Post-Meeting O/N (%)": "Post O/N (%)",
        "Expected Move (bp)": "Move (bp)",
        "Cumulative Move (bp)": "Cum Move (bp)",
        "Expected Steps": "Steps",
        "% of Step": "% of Step"
    })

    for col in df.columns:
        if pd.api.types.is_numeric_dtype(df[col]):
            if "bp" in col.lower():
                df[col] = df[col].round(1)
            elif "%" in col:
                df[col] = df[col].round(3)
            else:
                df[col] = df[col].round(3)

    return df


def build_methodology_table(
    curve_name,
    curve_ticker,
    on_ticker,
    current_on_rate,
    today,
    year_end,
    diagnostics,
    max_fit_error
):
    rows = [
        ["Curve", f"{curve_name} / {curve_ticker}"],
        ["Curve Side", diagnostics.get("Curve Side", "")],
        ["Curve Construction", diagnostics.get("Curve Construction", "")],
        ["Current O/N", f"{on_ticker}: {current_on_rate:.3f}%"],
        ["Meeting Horizon", f"Future rate decisions from {today} through {year_end}"],
        ["Meeting Filter", "BQL central bank calendar; rate-decision events only"],
        ["Solver", diagnostics.get("Solver", "")],
        [
            "Multiple Meetings per Curve Bucket",
            "If more than one meeting falls before the next usable tenor, the model solves "
            "a terminal bucket rate and allocates meeting levels using the selected interpolation method."
        ],
        ["Interpolation Method", diagnostics.get("Interpolation Method", "")],
        [
            "Interpolation Shape",
            f"{diagnostics.get('Interpolation Shape', '')}. Used only for Front-loaded "
            "and Back-loaded methods. Shape=2 means quadratic."
        ],
        [
            "Minimum Days to Next Tenor",
            f"{diagnostics.get('Min Days to Next Tenor', '')}. If a meeting is closer than "
            "this to the next curve tenor, that tenor is skipped for that meeting."
        ],
        [
            "Fit Error Definition",
            "Maximum absolute difference, in bp, between log-DF market-implied rates "
            "and model-rebuilt rates inside the displayed/model-relevant horizon."
        ],
        ["Chart End Date", str(diagnostics.get("Chart End Date", ""))],
        ["Boundary Date", str(diagnostics.get("Boundary Meeting Date", ""))],
        ["Boundary Source", diagnostics.get("Boundary Source", "")],
        ["Meetings Solved", diagnostics.get("Number of Meetings Solved", "")],
        ["Instruments Used", diagnostics.get("Number of Instruments Used", "")],
        [
            "Max Displayed-Horizon Fit Error",
            f"{max_fit_error:.2f} bp" if np.isfinite(max_fit_error) else "N/A"
        ]
    ]

    return pd.DataFrame(rows, columns=["Item", "Value"])


