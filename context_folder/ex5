def get_chart_end_date(meeting_table, model_meetings_df=None, curve_df=None, buffer_days=30):
    candidates = []

    if meeting_table is not None and not meeting_table.empty:
        if "Segment End" in meeting_table.columns:
            candidates.extend([to_date(x) for x in meeting_table["Segment End"].dropna().tolist()])
        if "Effective Date" in meeting_table.columns:
            candidates.extend([to_date(x) for x in meeting_table["Effective Date"].dropna().tolist()])
        if "Meeting" in meeting_table.columns:
            candidates.extend([to_date(x) for x in meeting_table["Meeting"].dropna().tolist()])

    if len(candidates) == 0 and model_meetings_df is not None and not model_meetings_df.empty:
        if "Effective Date" in model_meetings_df.columns:
            candidates.extend([to_date(x) for x in model_meetings_df["Effective Date"].dropna().tolist()])

    if len(candidates) == 0 and curve_df is not None and not curve_df.empty:
        candidates.extend([x.date() for x in pd.to_datetime(curve_df["maturity"]).dropna().tolist()])

    if len(candidates) == 0:
        return dt.date.today() + dt.timedelta(days=365)

    return max(candidates) + dt.timedelta(days=int(buffer_days))


