def build_curve_plot_nodes_with_on_anchor(curve_df, curve_logdf_df, current_on_rate, chart_end_date):
    valuation_date = curve_df.attrs.get("valuation_date", dt.date.today())
    valuation_date = to_date(valuation_date)
    chart_end_date = to_date(chart_end_date)

    curve_plot_df = curve_logdf_df.copy()
    curve_plot_df["maturity_date"] = pd.to_datetime(curve_plot_df["maturity"]).dt.date

    curve_plot_df = curve_plot_df[
        (curve_plot_df["maturity_date"] >= valuation_date) &
        (curve_plot_df["maturity_date"] <= chart_end_date)
    ].copy()

    on_anchor = pd.DataFrame({
        "ID": ["Current O/N"],
        "maturity": [pd.Timestamp(valuation_date)],
        "maturity_date": [valuation_date],
        "days_to_maturity": [0],
        "rate": [float(current_on_rate)],
        "discount_factor": [1.0],
        "log_discount_factor": [0.0]
    })

    keep_cols = [
        "ID",
        "maturity",
        "maturity_date",
        "days_to_maturity",
        "rate",
        "discount_factor",
        "log_discount_factor"
    ]

    curve_plot_df = curve_plot_df[[c for c in keep_cols if c in curve_plot_df.columns]].copy()
    curve_plot_df = pd.concat([on_anchor, curve_plot_df], ignore_index=True)

    curve_plot_df = curve_plot_df.dropna(subset=["maturity", "rate"])
    curve_plot_df = curve_plot_df.sort_values("maturity")
    curve_plot_df = curve_plot_df.drop_duplicates(subset=["maturity"], keep="first")
    curve_plot_df = curve_plot_df.reset_index(drop=True)

    return curve_plot_df


def build_market_curve_from_logdf_grid(
    logdf_fn,
    valuation_date,
    max_days,
    basis=360,
    max_points=250
):
    if max_days <= 0:
        return pd.DataFrame(columns=["date", "rate"])

    day_grid = np.linspace(0.0, float(max_days), max_points)

    dates = []
    rates = []

    for d in day_grid:
        d_int = int(round(float(d)))
        date = pd.Timestamp(valuation_date) + pd.Timedelta(days=d_int)

        if d_int <= 0:
            rate = np.nan
        else:
            rate = market_par_rate_from_logdf_fn(
                logdf_fn=logdf_fn,
                days=d_int,
                basis=basis
            )

        dates.append(date)
        rates.append(rate)

    return pd.DataFrame({
        "date": dates,
        "rate": rates
    })


def build_policy_dashboard(
    meeting_table,
    curve_df,
    curve_logdf_df,
    logdf_fn,
    current_on_rate,
    title,
    chart_end_date=None,
    basis=360
):
    mtg = meeting_table.copy()

    if mtg.empty:
        raise ValueError("No meeting results to plot.")

    valuation_date = curve_df.attrs.get("valuation_date", dt.date.today())
    valuation_date = to_date(valuation_date)

    if chart_end_date is None:
        chart_end_date = get_chart_end_date(
            meeting_table=meeting_table,
            curve_df=curve_df,
            buffer_days=30
        )

    chart_end_date = to_date(chart_end_date)
    max_days = actual_days(valuation_date, chart_end_date)

    curve_plot_df = build_curve_plot_nodes_with_on_anchor(
        curve_df=curve_df,
        curve_logdf_df=curve_logdf_df,
        current_on_rate=current_on_rate,
        chart_end_date=chart_end_date
    )

    market_smooth_df = build_market_curve_from_logdf_grid(
        logdf_fn=logdf_fn,
        valuation_date=valuation_date,
        max_days=max_days,
        basis=basis,
        max_points=250
    )

    market_smooth_df["rate"] = market_smooth_df["rate"].fillna(current_on_rate)

    rebuilt_rates = []
    no_change_rates = []

    for d in market_smooth_df["date"]:
        rebuilt_rate = model_rebuilt_par_rate_to_date(
            valuation_date=valuation_date,
            maturity_date=d.date(),
            current_on_rate_pct=current_on_rate,
            meeting_table=meeting_table,
            basis=basis
        )

        no_change_rate = no_change_zero_rate_to_date(
            valuation_date=valuation_date,
            maturity_date=d.date(),
            current_on_rate_pct=current_on_rate,
            basis=basis
        )

        rebuilt_rates.append(rebuilt_rate)
        no_change_rates.append(no_change_rate)

    market_smooth_df["model_rebuilt_rate"] = rebuilt_rates
    market_smooth_df["no_change_rate"] = no_change_rates

    mtg["Effective_dt"] = pd.to_datetime(mtg["Effective Date"])
    mtg = mtg.sort_values("Effective_dt").reset_index(drop=True)

    step_dates = [pd.Timestamp(valuation_date)]
    step_rates = [float(current_on_rate)]

    for _, row in mtg.iterrows():
        step_dates.append(pd.Timestamp(row["Effective Date"]))
        step_rates.append(float(row["Post-Meeting O/N (%)"]))

    step_dates.append(pd.Timestamp(chart_end_date))
    step_rates.append(step_rates[-1])

    curve_side = curve_df.attrs.get("curve_side", "")
    curve_label_suffix = f" ({curve_side})" if curve_side else ""

    fig = go.Figure()

    fig.add_trace(
        go.Scatter(
            x=market_smooth_df["date"],
            y=market_smooth_df["rate"],
            mode="lines",
            name=f"TIIE RFR Log-DF Market Curve{curve_label_suffix}",
            line=dict(width=3, color="#00C2FF"),
            hovertemplate="Date=%{x|%Y-%m-%d}<br>Market Curve=%{y:.3f}%<extra></extra>"
        )
    )

    fig.add_trace(
        go.Scatter(
            x=pd.to_datetime(curve_plot_df["maturity"]),
            y=curve_plot_df["rate"],
            mode="markers",
            name=f"TIIE RFR Nodes + O/N Anchor{curve_label_suffix}",
            marker=dict(size=8, color="#00C2FF", symbol="circle-open"),
            hovertemplate="Date=%{x|%Y-%m-%d}<br>Rate=%{y:.3f}%<extra></extra>"
        )
    )

    fig.add_trace(
        go.Scatter(
            x=market_smooth_df["date"],
            y=market_smooth_df["model_rebuilt_rate"],
            mode="lines",
            name="Model-Rebuilt Curve",
            line=dict(width=2.5, color="#7CFF6B", dash="dash"),
            hovertemplate="Date=%{x|%Y-%m-%d}<br>Model=%{y:.3f}%<extra></extra>"
        )
    )

    fig.add_trace(
        go.Scatter(
            x=market_smooth_df["date"],
            y=market_smooth_df["no_change_rate"],
            mode="lines",
            name="No-Change Carry Curve",
            line=dict(width=2, color="#AAAAAA", dash="dot"),
            hovertemplate="Date=%{x|%Y-%m-%d}<br>No-Change=%{y:.3f}%<extra></extra>"
        )
    )

    fig.add_trace(
        go.Scatter(
            x=step_dates,
            y=step_rates,
            mode="lines+markers",
            name="Implied Post-Meeting O/N Path",
            line=dict(width=3, color="#FFB000", shape="hv"),
            marker=dict(size=7, color="#FFB000"),
            hovertemplate="Date=%{x|%Y-%m-%d}<br>Post-Meeting O/N=%{y:.3f}%<extra></extra>"
        )
    )

    fig.add_vline(
        x=pd.Timestamp(valuation_date),
        line_width=1,
        line_dash="dot",
        line_color="orange"
    )

    fig.add_annotation(
        x=pd.Timestamp(valuation_date),
        y=1.02,
        yref="paper",
        xanchor="left",
        yanchor="bottom",
        text="Today",
        showarrow=False,
        font=dict(color="orange")
    )

    visible_rates = []
    visible_rates.extend(list(market_smooth_df["rate"].dropna()))
    visible_rates.extend(list(market_smooth_df["model_rebuilt_rate"].dropna()))
    visible_rates.extend(list(market_smooth_df["no_change_rate"].dropna()))
    visible_rates.extend(step_rates)

    y_min = min(visible_rates)
    y_max = max(visible_rates)
    y_pad = max((y_max - y_min) * 0.15, 0.05)

    fig.update_yaxes(
        title_text="Rate (%)",
        range=[y_min - y_pad, y_max + y_pad]
    )

    fig.update_xaxes(
        title_text="Date",
        range=[pd.Timestamp(valuation_date), pd.Timestamp(chart_end_date)],
        tickformat="%Y-%m-%d"
    )

    fig.update_layout(
        title=dict(
            text=title,
            x=0.02,
            y=0.96,
            xanchor="left",
            yanchor="top"
        ),
        height=700,
        template="plotly_dark",
        hovermode="x unified",
        legend=dict(
            orientation="h",
            yanchor="top",
            y=-0.18,
            xanchor="left",
            x=0.0,
            bgcolor="rgba(0,0,0,0)"
        ),
        margin=dict(t=90, r=35, l=75, b=130)
    )

    return go.FigureWidget(fig)


