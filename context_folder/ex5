# =========================
# LOG-DF CURVE CONSTRUCTION
# =========================
def build_logdf_curve(df_curve, current_on_rate_pct=None, basis=360):
    """
    Builds a smooth log discount factor curve from TIIE RFR quote nodes.

    Steps:
    1. Treat short-end TIIE RFR quotes as bullet/par OIS-style quotes.
    2. Convert each quote to a discount factor.
    3. Interpolate log discount factors with PCHIP.
    4. Anchor at t=0 with DF=1, logDF=0.
    """
    curve = df_curve.copy().sort_values("days_to_maturity").reset_index(drop=True)
    curve["days_to_maturity"] = pd.to_numeric(curve["days_to_maturity"], errors="coerce")
    curve["rate"] = pd.to_numeric(curve["rate"], errors="coerce")

    curve = curve.dropna(subset=["days_to_maturity", "rate"])
    curve = curve[curve["days_to_maturity"] > 0].copy()

    if curve.empty:
        raise ValueError("Curve data is empty after filtering for log-DF construction.")

    curve["discount_factor"] = curve.apply(
        lambda r: bullet_discount_factor_from_par_rate(
            rate_pct=r["rate"],
            tenor_days=int(r["days_to_maturity"]),
            basis=basis
        ),
        axis=1
    )

    curve["log_discount_factor"] = np.log(curve["discount_factor"])

    curve = curve.dropna(subset=["discount_factor", "log_discount_factor"])
    curve = curve[curve["discount_factor"] > 0].copy()

    if curve.empty:
        raise ValueError("No valid discount factors could be built from curve rates.")

    node_days = np.r_[0.0, curve["days_to_maturity"].to_numpy(float)]
    node_logdfs = np.r_[0.0, curve["log_discount_factor"].to_numpy(float)]

    unique_mask = np.concatenate([[True], np.diff(node_days) > 0])
    node_days = node_days[unique_mask]
    node_logdfs = node_logdfs[unique_mask]

    if len(node_days) < 2:
        raise ValueError("Not enough log-DF nodes to build curve.")

    if HAS_SCIPY:
        logdf_fn = PchipInterpolator(node_days, node_logdfs, extrapolate=True)
    else:
        def logdf_fn(x):
            return np.interp(float(x), node_days, node_logdfs)

    return curve, logdf_fn, node_days, node_logdfs


def logdf_at_days(logdf_fn, days):
    if days <= 0:
        return 0.0
    return float(logdf_fn(float(days)))


def market_par_rate_from_logdf_fn(logdf_fn, days, basis=360):
    if days <= 0:
        return np.nan
    logdf = logdf_at_days(logdf_fn, days)
    return par_rate_from_logdf(logdf, days, basis=basis)


# =========================
# MODEL PATH REBUILD
# =========================
def model_log_factor_to_date(
    valuation_date,
    maturity_date,
    current_on_rate_pct,
    meeting_table,
    basis=360
):
    """
    Returns model-implied log accumulation from valuation_date to maturity_date
    using the meeting-step path.
    """
    valuation_date = to_date(valuation_date)
    maturity_date = to_date(maturity_date)

    tenor_days = actual_days(valuation_date, maturity_date)

    if tenor_days <= 0:
        return 0.0

    if meeting_table is None or len(meeting_table) == 0:
        mtg = pd.DataFrame()
    else:
        mtg = meeting_table.copy()
        mtg["Effective Date"] = mtg["Effective Date"].apply(to_date)
        mtg = mtg[
            (mtg["Effective Date"] > valuation_date) &
            (mtg["Effective Date"] < maturity_date)
        ].copy()
        mtg = mtg.sort_values("Effective Date")

    log_factor = 0.0
    seg_start = valuation_date
    seg_rate = float(current_on_rate_pct)

    for _, row in mtg.iterrows():
        eff_date = row["Effective Date"]
        post_rate = float(row["Post-Meeting O/N (%)"])

        days = actual_days(seg_start, eff_date)

        if days > 0:
            daily_log = daily_log_from_annual_pct(seg_rate, basis=basis)

            if not np.isfinite(daily_log):
                return np.nan

            log_factor += daily_log * days

        seg_start = eff_date
        seg_rate = post_rate

    final_days = actual_days(seg_start, maturity_date)

    if final_days > 0:
        daily_log = daily_log_from_annual_pct(seg_rate, basis=basis)

        if not np.isfinite(daily_log):
            return np.nan

        log_factor += daily_log * final_days

    return log_factor


def model_rebuilt_par_rate_to_date(
    valuation_date,
    maturity_date,
    current_on_rate_pct,
    meeting_table,
    basis=360
):
    valuation_date = to_date(valuation_date)
    maturity_date = to_date(maturity_date)

    tenor_days = actual_days(valuation_date, maturity_date)

    if tenor_days <= 0:
        return current_on_rate_pct

    log_factor = model_log_factor_to_date(
        valuation_date=valuation_date,
        maturity_date=maturity_date,
        current_on_rate_pct=current_on_rate_pct,
        meeting_table=meeting_table,
        basis=basis
    )

    if not np.isfinite(log_factor):
        return np.nan

    return annual_pct_from_log_accumulation(
        log_factor=log_factor,
        tenor_days=tenor_days,
        basis=basis
    )


