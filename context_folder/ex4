# INTERPOLATED MEETING SOLVER
# =========================
def build_forward_curve_intervals(df_curve, current_on_rate_pct, basis=360):
    """
    Converts zero-ish curve instruments into forward average daily-log intervals.

    For instrument maturity T:
        log_factor(0,T) is derived from the quoted instrument rate.

    The forward interval from previous curve maturity to T is:
        [log_factor(0,T) - log_factor(0,prev_T)] / days(prev_T,T)
    """
    valuation_date = df_curve.attrs.get("valuation_date", dt.date.today())
    valuation_date = to_date(valuation_date)

    curve_nodes = df_curve.copy().sort_values("maturity").reset_index(drop=True)

    intervals = []

    prev_date = valuation_date
    prev_log_factor = 0.0
    prev_maturity_days = 0

    for _, inst in curve_nodes.iterrows():
        inst_id = inst["ID"]
        maturity_date = inst["maturity"].date()
        inst_rate = float(inst["rate"])

        tenor_days = actual_days(valuation_date, maturity_date)

        if tenor_days <= 0:
            continue

        total_log_factor = instrument_log_factor_from_annual_pct(
            rate_pct=inst_rate,
            tenor_days=tenor_days,
            basis=basis
        )

        if not np.isfinite(total_log_factor):
            continue

        interval_days = actual_days(prev_date, maturity_date)

        if interval_days <= 0:
            continue

        forward_avg_daily_log = (total_log_factor - prev_log_factor) / interval_days
        forward_avg_rate_pct = annual_pct_from_daily_log(forward_avg_daily_log, basis=basis)

        intervals.append({
            "Instrument": inst_id,
            "Interval Start": prev_date,
            "Interval End": maturity_date,
            "Instrument Maturity": maturity_date,
            "Instrument Rate (%)": inst_rate,
            "Tenor Days": tenor_days,
            "Interval Days": interval_days,
            "Previous Maturity Days": prev_maturity_days,
            "Total Log Factor": total_log_factor,
            "Previous Log Factor": prev_log_factor,
            "Forward Avg Daily Log": forward_avg_daily_log,
            "Forward Avg Rate (%)": forward_avg_rate_pct
        })

        prev_date = maturity_date
        prev_log_factor = total_log_factor
        prev_maturity_days = tenor_days

    intervals_df = pd.DataFrame(intervals)

    if intervals_df.empty:
        raise ValueError("Could not create forward curve intervals from curve data.")

    return intervals_df, valuation_date


def rate_path_avg_daily_log_to_maturity(
    valuation_date,
    maturity_date,
    current_on_rate_pct,
    meeting_table,
    basis=360
):
    """
    Rebuilds model-implied average daily log rate from valuation date to maturity
    using the solved meeting path.
    """
    valuation_date = to_date(valuation_date)
    maturity_date = to_date(maturity_date)

    tenor_days = actual_days(valuation_date, maturity_date)

    if tenor_days <= 0:
        return np.nan

    mtg = meeting_table.copy()

    if not mtg.empty:
        mtg["Effective Date"] = mtg["Effective Date"].apply(to_date)
        mtg = mtg[
            (mtg["Effective Date"] > valuation_date) &
            (mtg["Effective Date"] < maturity_date)
        ].copy()
        mtg = mtg.sort_values("Effective Date")

    segments = []
    seg_start = valuation_date
    seg_rate = float(current_on_rate_pct)

    for _, row in mtg.iterrows():
        eff_date = row["Effective Date"]
        post_rate = float(row["Post-Meeting O/N (%)"])

        days = actual_days(seg_start, eff_date)

        if days > 0:
            segments.append((days, seg_rate))

        seg_start = eff_date
        seg_rate = post_rate

    final_days = actual_days(seg_start, maturity_date)

    if final_days > 0:
        segments.append((final_days, seg_rate))

    log_sum = 0.0

    for days, rate in segments:
        dl = daily_log_from_annual_pct(rate, basis=basis)

        if not np.isfinite(dl):
            return np.nan

        log_sum += dl * days

    return log_sum / tenor_days


def solve_meeting_levels_interpolated(
    df_curve,
    model_meetings_df,
    current_on_rate_pct,
    step_size_pct,
    basis=360,
    interpolation_method="Linear",
    interpolation_shape=2.0,
    min_unknown_days=7,
    min_days_to_next_tenor=10
):
    """
    Corrected solver.

    Main idea:
    - Do NOT solve only tiny forward windows when a meeting is close to a tenor.
    - For each curve tenor, use the cumulative market rate from today to that tenor.
    - Subtract the already-known model path up to the current solve start.
    - Solve all currently unsolved meetings that are before the tenor and are at least
      min_days_to_next_tenor days before that tenor.
    - If a meeting is too close to the tenor, roll it into the next tenor bucket.

    This avoids weird huge moves caused by solving a meeting with only a few days of exposure.
    """
    valuation_date = df_curve.attrs.get("valuation_date", dt.date.today())
    valuation_date = to_date(valuation_date)

    curve_nodes = df_curve.copy().sort_values("maturity").reset_index(drop=True)
    curve_nodes["maturity_date"] = pd.to_datetime(curve_nodes["maturity"]).dt.date

    curve_nodes = curve_nodes[
        curve_nodes["maturity_date"] > valuation_date
    ].copy()

    if curve_nodes.empty:
        raise ValueError("No valid TIIE RFR curve nodes after valuation date.")

    meetings_df = model_meetings_df.copy()
    meetings_df["Meeting Date"] = meetings_df["Meeting Date"].apply(to_date)
    meetings_df["Effective Date"] = meetings_df["Effective Date"].apply(to_date)

    meetings_df = meetings_df[
        meetings_df["Effective Date"].apply(lambda x: actual_days(valuation_date, x) > 0)
    ].copy()

    requested_df = meetings_df[meetings_df["Requested"] == True].copy()
    requested_df = requested_df.sort_values("Effective Date").reset_index(drop=True)

    boundary_df = meetings_df[meetings_df["Boundary Only"] == True].copy()
    boundary_df = boundary_df.sort_values("Effective Date").reset_index(drop=True)

    if requested_df.empty:
        raise ValueError("No requested meetings available after valuation date.")

    meeting_rows = []
    instrument_fit_rows = []
    bucket_rows = []

    previous_rate = float(current_on_rate_pct)
    solved_effective_dates = set()

    # This is the start date of the unsolved block.
    # Initially today. After solving against a tenor, move this to that tenor.
    solve_start_date = valuation_date

    for _, inst in curve_nodes.iterrows():
        maturity_date = inst["maturity_date"]
        tenor_days = actual_days(valuation_date, maturity_date)

        if tenor_days <= 0:
            continue

        market_rate = float(inst["rate"])
        no_change_rate_to_tenor = no_change_zero_rate_to_date(
            valuation_date=valuation_date,
            maturity_date=maturity_date,
            current_on_rate_pct=current_on_rate_pct,
            basis=basis
        )
        
        market_vs_no_change_bp = (
            market_rate - no_change_rate_to_tenor
        ) * 100.0 if np.isfinite(no_change_rate_to_tenor) else np.nan
        target_total_log_factor = instrument_log_factor_from_annual_pct(
            rate_pct=market_rate,
            tenor_days=tenor_days,
            basis=basis
        )

        if not np.isfinite(target_total_log_factor):
            continue

        # Unsolved meetings between the current solve start and this tenor.
        candidates = requested_df[
            (~requested_df["Effective Date"].isin(solved_effective_dates)) &
            (requested_df["Effective Date"] > solve_start_date) &
            (requested_df["Effective Date"] < maturity_date)
        ].copy()
        
        candidates["Days to Tenor"] = candidates["Effective Date"].apply(
            lambda x: actual_days(x, maturity_date)
        )
        
        candidates = candidates.sort_values("Effective Date").reset_index(drop=True)
        
        if candidates.empty:
            bucket_rows.append({
                "Curve Bucket": inst["ID"],
                "Tenor Date": maturity_date,
                "Market Rate (%)": market_rate,
                "Meetings Solved in Bucket": 0,
                "Reason": "No unsolved meetings between solve start and tenor",
                "Min Days to Tenor": int(min_days_to_next_tenor)
            })
            continue
        
        # If any candidate meeting is too close to this tenor, skip this tenor entirely.
        # This prevents the model from solving part of the bucket and accidentally
        # rolling over a meeting that should have remained unsolved.
        too_close_mask = candidates["Days to Tenor"] < int(min_days_to_next_tenor)
        
        if too_close_mask.any():
            bucket_rows.append({
                "Curve Bucket": inst["ID"],
                "Tenor Date": maturity_date,
                "Market Rate (%)": market_rate,
                "Meetings Solved in Bucket": 0,
                "Reason": (
                    "Skipped tenor because at least one unsolved meeting is too close "
                    "to this tenor"
                ),
                "Closest Meeting": candidates.loc[too_close_mask, "Effective Date"].min(),
                "Min Actual Days to Tenor": candidates["Days to Tenor"].min(),
                "Min Days to Tenor": int(min_days_to_next_tenor)
            })
            continue
        
        eligible = candidates.copy()

        # Known model log factor from today to solve_start_date.
        known_log_to_start = model_log_factor_to_date(
            valuation_date=valuation_date,
            maturity_date=solve_start_date,
            current_on_rate_pct=current_on_rate_pct,
            meeting_table=pd.DataFrame(meeting_rows),
            basis=basis
        )

        remaining_days = actual_days(solve_start_date, maturity_date)

        if remaining_days <= 0:
            continue

        target_remaining_avg_daily_log = (
            target_total_log_factor - known_log_to_start
        ) / remaining_days

        effective_dates = eligible["Effective Date"].tolist()

        if len(effective_dates) == 1:
            solved_rate = solve_single_meeting_rate_for_interval(
                interval_start=solve_start_date,
                interval_end=maturity_date,
                meeting_date=effective_dates[0],
                start_rate_pct=previous_rate,
                target_avg_daily_log=target_remaining_avg_daily_log,
                basis=basis
            )

            solved_rates = [solved_rate]
            solved_terminal_rate = solved_rate
            allocation_method_used = "Exact single-meeting cumulative solve"

        else:
            solved_rates, solved_terminal_rate = solve_multi_meeting_rates_for_interval(
                interval_start=solve_start_date,
                interval_end=maturity_date,
                start_rate_pct=previous_rate,
                meeting_dates=effective_dates,
                target_avg_daily_log=target_remaining_avg_daily_log,
                method=interpolation_method,
                shape=interpolation_shape,
                basis=basis
            )

            allocation_method_used = f"{interpolation_method} cumulative interpolation"

        pre_rate = previous_rate

        for k, (_, mtg) in enumerate(eligible.iterrows()):
            meeting_date = mtg["Meeting Date"]
            effective_date = mtg["Effective Date"]
            post_rate = float(solved_rates[k])

            if k + 1 < len(eligible):
                segment_end = eligible.loc[k + 1, "Effective Date"]
            else:
                segment_end = maturity_date

            expected_move = post_rate - pre_rate if np.isfinite(post_rate) else np.nan
            expected_move_bp = expected_move * 100.0 if np.isfinite(expected_move) else np.nan

            expected_steps, whole_steps, probability = decompose_hike_probability(
                expected_move_pct=expected_move,
                step_size_pct=step_size_pct
            )

            total_bucket_days = actual_days(solve_start_date, maturity_date)

            if total_bucket_days > 0:
                t_in_bucket = actual_days(solve_start_date, effective_date) / float(total_bucket_days)
            else:
                t_in_bucket = np.nan

            meeting_rows.append({
                "Meeting": meeting_date,
                "Effective Date": effective_date,
                "Segment End": segment_end,
                "Curve Interval Start": solve_start_date,
                "Curve Interval End": maturity_date,
                "Curve Instrument": inst["ID"],
                "Curve Instrument Rate (%)": market_rate,
                "Forward Avg Rate (%)": annual_pct_from_daily_log(
                    target_remaining_avg_daily_log,
                    basis=basis
                ),
                "Interpolation Method": allocation_method_used,
                "Interpolation t": t_in_bucket,
                "Days to Tenor": actual_days(effective_date, maturity_date),
                "Pre-Meeting O/N (%)": pre_rate,
                "Post-Meeting O/N (%)": post_rate,
                "Cumulative Move (%)": post_rate - current_on_rate_pct if np.isfinite(post_rate) else np.nan,
                "Cumulative Move (bp)": (post_rate - current_on_rate_pct) * 100.0 if np.isfinite(post_rate) else np.nan,
                "Expected Move (%)": expected_move,
                "Expected Move (bp)": expected_move_bp,
                "Expected Steps": expected_steps,
                "# Steps": whole_steps,
                "% of Step": probability,
                "No-Change Rate to Tenor (%)": no_change_rate_to_tenor,
                "Market vs No-Change (bp)": market_vs_no_change_bp
            })

            solved_effective_dates.add(effective_date)
            pre_rate = post_rate
            previous_rate = post_rate

        bucket_rows.append({
            "Curve Bucket": inst["ID"],
            "Tenor Date": maturity_date,
            "Market Rate (%)": market_rate,
            "Meetings Solved in Bucket": len(eligible),
            "Allocation Method": allocation_method_used,
            "Solved Terminal Rate (%)": solved_terminal_rate,
            "Solve Start Date": solve_start_date,
            "Target Remaining Avg Rate (%)": annual_pct_from_daily_log(
                target_remaining_avg_daily_log,
                basis=basis
            ),
            "Min Days to Tenor": int(min_days_to_next_tenor)
        })

        # After fitting this tenor, the path is considered explained through this tenor.
        solve_start_date = maturity_date

        if len(solved_effective_dates) >= len(requested_df):
            break

    meeting_table = pd.DataFrame(meeting_rows)

    if meeting_table.empty:
        raise ValueError(
            "No meeting path could be solved. Try lowering the minimum days-to-tenor input "
            "or extending the curve horizon."
        )

    meeting_table = meeting_table.sort_values("Effective Date").reset_index(drop=True)

    chart_end_date = get_chart_end_date(
        meeting_table=meeting_table,
        model_meetings_df=model_meetings_df,
        curve_df=df_curve,
        buffer_days=30
    )

    # Fit table only for displayed/model-relevant horizon.
    fit_curve_nodes = curve_nodes[
        curve_nodes["maturity_date"] <= chart_end_date
    ].copy()

    if fit_curve_nodes.empty:
        fit_curve_nodes = curve_nodes.head(1).copy()

    for _, inst in fit_curve_nodes.iterrows():
        maturity_date = inst["maturity_date"]
        tenor_days = actual_days(valuation_date, maturity_date)

        if tenor_days <= 0:
            continue

        actual_rate = float(inst["rate"])

        rebuilt_rate = model_zero_rate_to_date(
            valuation_date=valuation_date,
            maturity_date=maturity_date,
            current_on_rate_pct=current_on_rate_pct,
            meeting_table=meeting_table,
            basis=basis
        )

        if np.isfinite(rebuilt_rate):
            rate_error_bp = (actual_rate - rebuilt_rate) * 100.0
        else:
            rate_error_bp = np.nan

        instrument_fit_rows.append({
            "Instrument": inst["ID"],
            "Instrument Maturity": maturity_date,
            "Instrument Rate (%)": actual_rate,
            "Model-Rebuilt Rate (%)": rebuilt_rate,
            "Rate Error (bp)": rate_error_bp,
            "Tenor Days": tenor_days,
            "Used In Fit": True
        })

    instrument_fit_table = pd.DataFrame(instrument_fit_rows)
    interval_allocation_table = pd.DataFrame(bucket_rows)

    diagnostics = {
        "Number of Instruments Used": int(len(curve_nodes)),
        "Number of Meetings Solved": int(len(meeting_table)),
        "Boundary Meeting Date": boundary_df["Meeting Date"].iloc[0] if not boundary_df.empty else "",
        "Boundary Effective Date": boundary_df["Effective Date"].iloc[0] if not boundary_df.empty else "",
        "Boundary Source": boundary_df["Boundary Source"].iloc[0] if not boundary_df.empty and "Boundary Source" in boundary_df.columns else "",
        "Basis": basis,
        "Min Unknown Days": min_unknown_days,
        "Min Days to Next Tenor": int(min_days_to_next_tenor),
        "Interpolation Method": interpolation_method,
        "Interpolation Shape": interpolation_shape,
        "Chart End Date": chart_end_date,
        "Solver": "Cumulative tenor solve with meeting roll-forward threshold",
        "Forward Curve Intervals": pd.DataFrame(),
        "Interval Allocation Table": interval_allocation_table,
        "Market Matrix Rank": np.nan,
        "Singular Values": np.array([]),
        "Condition Number": np.nan,
        "Residual Sum of Squares": np.nan,
        "Curve Side": df_curve.attrs.get("curve_side", ""),
    }

    return meeting_table, instrument_fit_table, diagnostics

