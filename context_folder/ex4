def date_to_ordinal(d):
    d = to_date(d)
    return pd.Timestamp(d).toordinal()


def ordinal_to_timestamp(x):
    return pd.Timestamp.fromordinal(int(round(float(x))))


def smooth_curve_points(curve_plot_df, valuation_date, max_points=250):
    df = curve_plot_df.copy()
    df = df.dropna(subset=["maturity", "rate"])
    df = df.sort_values("maturity")

    if df.empty:
        return pd.DataFrame(columns=["date", "rate"])

    x_nodes = np.array(
        [date_to_ordinal(x.date()) for x in pd.to_datetime(df["maturity"])],
        dtype=float
    )
    y_nodes = np.array(df["rate"], dtype=float)

    unique_mask = np.concatenate([[True], np.diff(x_nodes) > 0])
    x_nodes = x_nodes[unique_mask]
    y_nodes = y_nodes[unique_mask]

    if len(x_nodes) == 1:
        return pd.DataFrame({
            "date": [ordinal_to_timestamp(x_nodes[0])],
            "rate": [y_nodes[0]]
        })

    x_grid = np.linspace(x_nodes.min(), x_nodes.max(), max_points)

    try:
        from scipy.interpolate import PchipInterpolator
        interpolator = PchipInterpolator(x_nodes, y_nodes)
        y_grid = interpolator(x_grid)
    except Exception:
        y_grid = np.interp(x_grid, x_nodes, y_nodes)

    return pd.DataFrame({
        "date": [ordinal_to_timestamp(x) for x in x_grid],
        "rate": y_grid
    })
