def get_current_overnight_rate(country_name, verbose=False):
    cfg = COUNTRY_MAP[country_name]
    ticker = cfg["overnight_rate_ticker"]

    request = bql.Request(
        ticker,
        {"PX_LAST": bq.data.px_last()}
    )

    response = bq.execute(request)
    df = _flatten_bql_df(response[0])

    if verbose:
        display(df)

    value_col = _find_col(df, ["PX_LAST", "px_last", "LAST_PRICE", "value"])

    if value_col is None:
        value_col = _first_numeric_col(df, exclude_cols=["ID"])

    if value_col is None:
        raise ValueError(f"Could not find numeric O/N rate column. Columns: {list(df.columns)}")

    rate = pd.to_numeric(df[value_col], errors="coerce").dropna()

    if rate.empty:
        raise ValueError(f"No valid O/N rate returned for {ticker}.")

    return float(rate.iloc[0]), ticker


