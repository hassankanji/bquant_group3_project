def run(event=None):
    min_days_to_next_tenor = int(min_days_to_tenor_input.value)
    spinner.layout.visibility = "visible"
    exception.value = ""
    output_container.children = []
    chart_container.children = []

    try:
        cfg = DEFAULT_MODEL_CONFIG.copy()

        country_name = country_dd.value
        curve_name = curve_dd.value
        curve_side = curve_side_dd.value
        interpolation_method = interpolation_dd.value
        interpolation_shape = safe_float(shape_input.value, cfg["interpolation_shape"])

        curve_df = get_curve_data(
            curve_name=curve_name,
            curve_side=curve_side,
            verbose=False
        )
        curve_ticker = curve_df.attrs.get("curve_ticker", CURVE_MAP[curve_name])
        front_rate_anchor = curve_df.attrs.get("front_rate_anchor", np.nan)

        current_on_rate, on_ticker = get_current_overnight_rate(
            country_name=country_name,
            verbose=False
        )

        model_meetings_df, today, year_end = build_meeting_calendar_for_model(
            country_name=country_name,
            effective_lag_days=cfg["effective_lag_days"],
            boundary_lookahead_days=cfg["boundary_lookahead_days"]
        )

        meeting_table, instrument_fit_table, diagnostics = solve_meeting_levels_interpolated(
            df_curve=curve_df,
            model_meetings_df=model_meetings_df,
            current_on_rate_pct=current_on_rate,
            step_size_pct=cfg["step_size_pct"],
            basis=cfg["basis"],
            interpolation_method=interpolation_method,
            interpolation_shape=interpolation_shape,
            min_unknown_days=cfg["min_unknown_days"],
            min_days_to_next_tenor=min_days_to_next_tenor
        )

        max_fit_error = instrument_fit_table["Rate Error (bp)"].abs().max()

        methodology_df = build_methodology_table(
            curve_name=curve_name,
            curve_ticker=curve_ticker,
            on_ticker=on_ticker,
            current_on_rate=current_on_rate,
            today=today,
            year_end=year_end,
            diagnostics=diagnostics,
            max_fit_error=max_fit_error
        )

        user_table = build_user_output_table(meeting_table)

        warnings = []

        if np.isfinite(front_rate_anchor):
            anchor_diff_bp = (front_rate_anchor - current_on_rate) * 100.0

            if abs(anchor_diff_bp) > 10:
                warnings.append(
                    f"Warning: front curve anchor differs from current O/N by {anchor_diff_bp:.1f} bp."
                )

        if interpolation_method in ["Front-loaded", "Back-loaded"] and interpolation_shape <= 0:
            warnings.append(
                "Warning: interpolation shape must be positive. The model used the default shape of 2.0."
            )

        if max_fit_error is not None and np.isfinite(max_fit_error) and abs(max_fit_error) > 10:
            warnings.append(
                f"Note: displayed-horizon max fit error is {max_fit_error:.2f} bp. "
                "Fit error is calculated only over the visible/model-relevant TIIE RFR curve horizon."
            )

        output_widgets = []

        warning_html = ""
        if len(warnings) > 0:
            warning_html = "<br>".join(warnings)

        output_widgets.append(
            widgets.HTML(
                value=f"""
                <h3>Methodology</h3>
                {warning_html}
                """
            )
        )

        output_widgets.append(render_dataframe_html(methodology_df))

        output_widgets.append(widgets.HTML(value="<h3>Implied Meeting Path</h3>"))

        output_widgets.append(render_dataframe_html(user_table))

        output_widgets.append(
            widgets.HTML(value=f"<b>Max instrument fit error:</b> {max_fit_error:.2f} bp")
        )

        if show_diagnostics_cb.value:
            output_widgets.append(widgets.HTML(value="<h3>Diagnostics</h3>"))

            diag_out = widgets.Output()
            with diag_out:
                print("Diagnostics")
                for k, v in diagnostics.items():
                    if k in ["Forward Curve Intervals", "Interval Allocation Table"]:
                        continue

                    if k == "Singular Values":
                        print(f"{k}: {np.array2string(v, precision=6)}")
                    else:
                        print(f"{k}: {v}")

                print("\nFiltered Model Meeting Calendar")
            output_widgets.append(diag_out)

            output_widgets.append(render_dataframe_html(model_meetings_df, max_height_px=300))

            output_widgets.append(widgets.HTML(value="<h4>Instrument Fit Table</h4>"))
            output_widgets.append(render_dataframe_html(instrument_fit_table, max_height_px=350))

            output_widgets.append(widgets.HTML(value="<h4>Forward Curve Intervals</h4>"))
            output_widgets.append(render_dataframe_html(diagnostics["Forward Curve Intervals"], max_height_px=350))

            output_widgets.append(widgets.HTML(value="<h4>Interval Allocation Table</h4>"))
            output_widgets.append(render_dataframe_html(diagnostics["Interval Allocation Table"], max_height_px=350))

            curve_nodes_display = curve_df[
                [
                    "ID",
                    "valuation_date",
                    "maturity",
                    "days_to_maturity",
                    "T_360",
                    "rate"
                ]
            ].copy()

            output_widgets.append(widgets.HTML(value="<h4>Curve Nodes</h4>"))
            output_widgets.append(render_dataframe_html(curve_nodes_display, max_height_px=350))

        output_container.children = output_widgets

        chart_end_date = diagnostics.get("Chart End Date", None)

        fig = build_policy_dashboard(
            meeting_table=meeting_table,
            curve_df=curve_df,
            current_on_rate=current_on_rate,
            title=f"{country_name} {curve_name}: Market Curve vs Model-Implied Meeting Path - {interpolation_method}",
            chart_end_date=chart_end_date,
            basis=cfg["basis"]
        )

        chart_container.children = [fig]

    except Exception as e:
        exception.value = f"<p style='word-wrap: break-word; color: red;'>Error: {e}</p>"

    finally:
        spinner.layout.visibility = "hidden"


