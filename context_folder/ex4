def build_user_output_table(meeting_table):
    df = meeting_table.copy()

    keep_cols = [
        "Meeting",
        "Segment End",
        "Curve Instrument",
        "Interpolation Method",
        "Days to Tenor",
        "Curve Instrument Rate (%)",
        "No-Change Rate to Tenor (%)",
        "Market vs No-Change (bp)",
        "Pre-Meeting O/N (%)",
        "Post-Meeting O/N (%)",
        "Expected Move (bp)",
        "Cumulative Move (bp)",
        "Expected Steps",
        "% of Step"
    ]

    df = df[[c for c in keep_cols if c in df.columns]].copy()

    df = df.rename(columns={
        "Meeting": "Meeting Date",
        "Segment End": "Priced Until",
        "Curve Instrument": "Curve Bucket",
        "Curve Instrument Rate (%)": "Market Rate (%)",
        "No-Change Rate to Tenor (%)": "No-Change Rate (%)",
        "Market vs No-Change (bp)": "Market - No Change (bp)",
        "Pre-Meeting O/N (%)": "Pre O/N (%)",
        "Post-Meeting O/N (%)": "Post O/N (%)",
        "Expected Move (bp)": "Move (bp)",
        "Cumulative Move (bp)": "Cum Move (bp)",
        "Expected Steps": "Steps",
        "% of Step": "% of Step"
    })

    for col in df.columns:
        if pd.api.types.is_numeric_dtype(df[col]):
            if "bp" in col.lower():
                df[col] = df[col].round(1)
            elif "%" in col:
                df[col] = df[col].round(3)
            else:
                df[col] = df[col].round(3)

    return df

def build_methodology_table(
    curve_name,
