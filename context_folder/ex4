        ["Boundary Date", str(diagnostics.get("Boundary Meeting Date", ""))],
        ["Boundary Source", diagnostics.get("Boundary Source", "")],
        ["Meetings Solved", diagnostics.get("Number of Meetings Solved", "")],
        ["Instruments Used", diagnostics.get("Number of Instruments Used", "")],
        [
            "Max Displayed-Horizon Fit Error",
            f"{max_fit_error:.2f} bp" if np.isfinite(max_fit_error) else "N/A"
        ]
    ]

    return pd.DataFrame(rows, columns=["Item", "Value"])
