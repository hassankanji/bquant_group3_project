def no_change_zero_rate_to_date(
    valuation_date,
    maturity_date,
    current_on_rate_pct,
    basis=360
):
    """
    Returns the market-equivalent zero/average rate if the current O/N rate
    stays unchanged until maturity.

    This is the correct benchmark for deciding whether the curve implies
    hikes or cuts.
    """
    valuation_date = to_date(valuation_date)
    maturity_date = to_date(maturity_date)

    tenor_days = actual_days(valuation_date, maturity_date)

    if tenor_days <= 0:
        return current_on_rate_pct

    current_daily_log = daily_log_from_annual_pct(
        current_on_rate_pct,
        basis=basis
    )

    if not np.isfinite(current_daily_log):
        return np.nan

    log_factor = current_daily_log * tenor_days

    return annual_pct_from_instrument_log_factor(
        log_factor=log_factor,
        tenor_days=tenor_days,
        basis=basis
    )
    
def model_log_factor_to_date(
    valuation_date,
    maturity_date,
    current_on_rate_pct,
    meeting_table,
    basis=360
):
    """
    Returns the model-implied log accumulation factor from valuation_date to maturity_date
    using the already-solved meeting path.

    This is more primitive than a rebuilt zero rate.
    The rebuilt zero rate is derived from this log factor.
    """
    valuation_date = to_date(valuation_date)
    maturity_date = to_date(maturity_date)

    tenor_days = actual_days(valuation_date, maturity_date)

    if tenor_days <= 0:
        return 0.0

    if meeting_table is None or len(meeting_table) == 0:
        mtg = pd.DataFrame()
    else:
        mtg = meeting_table.copy()
        mtg["Effective Date"] = mtg["Effective Date"].apply(to_date)
        mtg = mtg[
            (mtg["Effective Date"] > valuation_date) &
            (mtg["Effective Date"] < maturity_date)
        ].copy()
        mtg = mtg.sort_values("Effective Date")

    log_factor = 0.0
    seg_start = valuation_date
    seg_rate = float(current_on_rate_pct)

    for _, row in mtg.iterrows():
        eff_date = row["Effective Date"]
        post_rate = float(row["Post-Meeting O/N (%)"])

        days = actual_days(seg_start, eff_date)

        if days > 0:
            daily_log = daily_log_from_annual_pct(seg_rate, basis=basis)

            if not np.isfinite(daily_log):
                return np.nan

            log_factor += daily_log * days

        seg_start = eff_date
        seg_rate = post_rate

    final_days = actual_days(seg_start, maturity_date)

    if final_days > 0:
        daily_log = daily_log_from_annual_pct(seg_rate, basis=basis)

        if not np.isfinite(daily_log):
            return np.nan

        log_factor += daily_log * final_days

    return log_factor



def model_zero_rate_to_date(
    valuation_date,
    maturity_date,
    current_on_rate_pct,
    meeting_table,
    basis=360
):
    """
    Rebuilds the zero/average rate from valuation_date to maturity_date
    using the implied post-meeting O/N step path.

    This is the line that should match the TIIE RFR curve.
    """
    valuation_date = to_date(valuation_date)
    maturity_date = to_date(maturity_date)

    tenor_days = actual_days(valuation_date, maturity_date)

    if tenor_days <= 0:
        return current_on_rate_pct

    mtg = meeting_table.copy()

    if not mtg.empty:
        mtg["Effective Date"] = mtg["Effective Date"].apply(to_date)
        mtg = mtg[
            (mtg["Effective Date"] > valuation_date) &
            (mtg["Effective Date"] < maturity_date)
        ].copy()
        mtg = mtg.sort_values("Effective Date")

    segments = []
    seg_start = valuation_date
    seg_rate = float(current_on_rate_pct)

    for _, row in mtg.iterrows():
        eff_date = row["Effective Date"]
        post_rate = float(row["Post-Meeting O/N (%)"])

        days = actual_days(seg_start, eff_date)

        if days > 0:
            segments.append((days, seg_rate))

        seg_start = eff_date
        seg_rate = post_rate

    final_days = actual_days(seg_start, maturity_date)

    if final_days > 0:
        segments.append((final_days, seg_rate))

    log_factor = 0.0

    for days, rate in segments:
        daily_log = daily_log_from_annual_pct(rate, basis=basis)

        if not np.isfinite(daily_log):
            return np.nan

        log_factor += daily_log * days

    return annual_pct_from_instrument_log_factor(
        log_factor=log_factor,
        tenor_days=tenor_days,
        basis=basis
    )


def build_curve_plot_nodes_with_on_anchor(curve_df, current_on_rate, chart_end_date):
    """
    Builds curve nodes for charting and adds the current O/N rate as the starting point.
    This is for plotting only.
    """
    valuation_date = curve_df.attrs.get("valuation_date", dt.date.today())
    valuation_date = to_date(valuation_date)
    chart_end_date = to_date(chart_end_date)

    curve_plot_df = curve_df.copy()
    curve_plot_df["maturity_date"] = pd.to_datetime(curve_plot_df["maturity"]).dt.date

    curve_plot_df = curve_plot_df[
        (curve_plot_df["maturity_date"] >= valuation_date) &
        (curve_plot_df["maturity_date"] <= chart_end_date)
    ].copy()

    on_anchor = pd.DataFrame({
        "ID": ["Current O/N"],
        "maturity": [pd.Timestamp(valuation_date)],
        "maturity_date": [valuation_date],
        "rate": [float(current_on_rate)]
    })

    keep_cols = ["ID", "maturity", "maturity_date", "rate"]

    curve_plot_df = curve_plot_df[[c for c in keep_cols if c in curve_plot_df.columns]].copy()
    curve_plot_df = pd.concat([on_anchor, curve_plot_df], ignore_index=True)

    curve_plot_df = curve_plot_df.dropna(subset=["maturity", "rate"])
    curve_plot_df = curve_plot_df.sort_values("maturity")
    curve_plot_df = curve_plot_df.drop_duplicates(subset=["maturity"], keep="first")
    curve_plot_df = curve_plot_df.reset_index(drop=True)

    return curve_plot_df

