def build_policy_dashboard(
    meeting_table,
    curve_df,
    current_on_rate,
    title,
    chart_end_date=None,
    basis=360
):
    """
    Chart now shows:
    1. TIIE RFR market curve, starting from current O/N.
    2. Model-rebuilt zero curve from the implied meeting path.
    3. Implied post-meeting O/N path as a step graph.

    The red current O/N line is removed.
    """
    mtg = meeting_table.copy()

    if mtg.empty:
        raise ValueError("No meeting results to plot.")

    valuation_date = curve_df.attrs.get("valuation_date", dt.date.today())
    valuation_date = to_date(valuation_date)

    if chart_end_date is None:
        chart_end_date = get_chart_end_date(
            meeting_table=meeting_table,
            curve_df=curve_df,
            buffer_days=30
        )

    chart_end_date = to_date(chart_end_date)

    curve_plot_df = build_curve_plot_nodes_with_on_anchor(
        curve_df=curve_df,
        current_on_rate=current_on_rate,
        chart_end_date=chart_end_date
    )

    if curve_plot_df.empty:
        raise ValueError("No TIIE RFR curve nodes available for charting.")

    # Smooth market curve including current O/N anchor.
    smooth_market_df = smooth_curve_points(
        curve_plot_df=curve_plot_df,
        valuation_date=valuation_date,
        max_points=250
    )

    # Model-rebuilt zero curve, using same x-grid as market smooth curve.
    rebuilt_rates = []

    for d in smooth_market_df["date"]:
        rebuilt_rate = model_zero_rate_to_date(
            valuation_date=valuation_date,
            maturity_date=d.date(),
            current_on_rate_pct=current_on_rate,
            meeting_table=meeting_table,
            basis=basis
        )
        rebuilt_rates.append(rebuilt_rate)

    smooth_market_df["model_rebuilt_rate"] = rebuilt_rates
    no_change_rates = []

    for d in smooth_market_df["date"]:
        no_change_rate = no_change_zero_rate_to_date(
            valuation_date=valuation_date,
            maturity_date=d.date(),
            current_on_rate_pct=current_on_rate,
            basis=basis
        )
        no_change_rates.append(no_change_rate)
    
    smooth_market_df["no_change_rate"] = no_change_rates
    

    # Step path starts at valuation date and continues through chart end.
    mtg["Effective_dt"] = pd.to_datetime(mtg["Effective Date"])
    mtg = mtg.sort_values("Effective_dt").reset_index(drop=True)

    step_dates = [pd.Timestamp(valuation_date)]
    step_rates = [float(current_on_rate)]

    for _, row in mtg.iterrows():
        step_dates.append(pd.Timestamp(row["Effective Date"]))
        step_rates.append(float(row["Post-Meeting O/N (%)"]))

    step_dates.append(pd.Timestamp(chart_end_date))
    step_rates.append(step_rates[-1])

    fig = go.Figure()

    # TIIE RFR market curve.
    fig.add_trace(
        go.Scatter(
            x=smooth_market_df["date"],
            y=smooth_market_df["rate"],
            mode="lines",
            name="TIIE RFR Market Curve",
            line=dict(width=3, color="#00C2FF"),
            hovertemplate="Date=%{x|%Y-%m-%d}<br>Market Curve=%{y:.3f}%<extra></extra>"
        )
    )

    # TIIE RFR market nodes.
    fig.add_trace(
        go.Scatter(
            x=pd.to_datetime(curve_plot_df["maturity"]),
            y=curve_plot_df["rate"],
            mode="markers",
            name="TIIE RFR Nodes + O/N Anchor",
            marker=dict(size=8, color="#00C2FF", symbol="circle-open"),
            hovertemplate="Date=%{x|%Y-%m-%d}<br>Rate=%{y:.3f}%<extra></extra>"
        )
    )

    # Model-rebuilt zero curve from meeting path.
    fig.add_trace(
        go.Scatter(
            x=smooth_market_df["date"],
            y=smooth_market_df["model_rebuilt_rate"],
            mode="lines",
            name="Model-Rebuilt Zero Curve",
            line=dict(width=2.5, color="#7CFF6B", dash="dash"),
            hovertemplate="Date=%{x|%Y-%m-%d}<br>Model Zero=%{y:.3f}%<extra></extra>"
        )
    )
    fig.add_trace(
        go.Scatter(
            x=smooth_market_df["date"],
            y=smooth_market_df["no_change_rate"],
            mode="lines",
            name="No-Change Carry Curve",
            line=dict(width=2, color="#AAAAAA", dash="dot"),
            hovertemplate="Date=%{x|%Y-%m-%d}<br>No-Change Carry=%{y:.3f}%<extra></extra>"
        )
    )
    # Implied meeting path as step function.
    fig.add_trace(
        go.Scatter(
            x=step_dates,
            y=step_rates,
            mode="lines+markers",
            name="Implied Post-Meeting O/N Path",
            line=dict(width=3, color="#FFB000", shape="hv"),
            marker=dict(size=7, color="#FFB000"),
            hovertemplate="Date=%{x|%Y-%m-%d}<br>Post-Meeting O/N=%{y:.3f}%<extra></extra>"
        )
    )

    fig.add_vline(
        x=pd.Timestamp(valuation_date),
        line_width=1,
        line_dash="dot",
        line_color="orange"
    )

    fig.add_annotation(
        x=pd.Timestamp(valuation_date),
        y=1.02,
        yref="paper",
        xanchor="left",
        yanchor="bottom",
        text="Today",
        showarrow=False,
        font=dict(color="orange")
    )

    visible_rates = []
    visible_rates.extend(list(smooth_market_df["rate"].dropna()))
    visible_rates.extend(list(smooth_market_df["model_rebuilt_rate"].dropna()))
    visible_rates.extend(list(smooth_market_df["no_change_rate"].dropna()))
    visible_rates.extend(step_rates)

    y_min = min(visible_rates)
    y_max = max(visible_rates)
    y_pad = max((y_max - y_min) * 0.15, 0.05)

    fig.update_yaxes(
        title_text="Rate (%)",
        range=[y_min - y_pad, y_max + y_pad]
    )

    fig.update_xaxes(
        title_text="Date",
        range=[pd.Timestamp(valuation_date), pd.Timestamp(chart_end_date)],
        tickformat="%Y-%m-%d"
    )

    fig.update_layout(
        title=dict(
            text=title,
            x=0.02,
            y=0.96,
            xanchor="left",
            yanchor="top"
        ),
        height=700,
        template="plotly_dark",
        hovermode="x unified",
        legend=dict(
            orientation="h",
            yanchor="top",
            y=-0.18,
            xanchor="left",
            x=0.0,
            bgcolor="rgba(0,0,0,0)"
        ),
        margin=dict(t=90, r=35, l=75, b=130)
    )

    return go.FigureWidget(fig)

