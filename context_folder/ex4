def get_central_bank_meetings_bql(country_name, start, end, verbose=False):
    cfg = COUNTRY_MAP[country_name]
    universe = cfg["country_universe"]

    include_keywords = [x.lower() for x in cfg["include_event_keywords"]]
    exclude_keywords = [x.lower() for x in cfg["exclude_event_keywords"]]
    ticker_root = cfg["rate_decision_ticker_root"].lower()

    start = to_date(start)
    end = to_date(end)

    data_item = bq.data.calendar(
        type="CENTRAL_BANKS",
        subtype="ALL_CENTRAL_BANKS",
        dates=bq.func.range(start.strftime("%Y-%m-%d"), end.strftime("%Y-%m-%d")),
        view="EXTENDED"
    )

    request = bql.Request(universe, data_item)
    response = bq.execute(request)

    cal_df = _flatten_bql_df(response[0])

    if verbose:
        display(cal_df)

    if cal_df.empty:
        raise ValueError("BQL central bank calendar returned no rows.")

    release_date_col = _find_col(
        cal_df,
        ["RELEASE_DATE", "release_date", "Release Date", "RELEASE_DATE_TIME", "release_date_time"]
    )

    event_name_col = _find_col(
        cal_df,
        ["EVENT_NAME", "event_name", "Event Name"]
    )

    release_time_col = _find_col(
        cal_df,
        ["RELEASE_TIME", "release_time", "Release Time"]
    )

    value_col = _find_col(
        cal_df,
        ["VALUE", "value", "calendar"]
    )

    if release_date_col is None:
        raise ValueError(f"Could not find release date column. Columns: {list(cal_df.columns)}")

    if event_name_col is None:
        raise ValueError(f"Could not find event name column. Columns: {list(cal_df.columns)}")

    df = cal_df.copy()

    df["Meeting Date"] = pd.to_datetime(df[release_date_col], errors="coerce").dt.date
    df["Event Name"] = df[event_name_col].astype(str)

    if release_time_col is not None:
        df["Release Time"] = df[release_time_col].astype(str)
    else:
        df["Release Time"] = ""

    if value_col is not None:
        df["Ticker"] = df[value_col].astype(str)
    else:
        df["Ticker"] = ""

    df = df.dropna(subset=["Meeting Date"]).copy()

    event_lower = df["Event Name"].str.lower()
    ticker_lower = df["Ticker"].str.lower()

    include_mask = (
        event_lower.apply(lambda x: any(k in x for k in include_keywords)) |
        ticker_lower.str.contains(ticker_root, na=False)
    )

    exclude_mask = event_lower.apply(lambda x: any(k in x for k in exclude_keywords))

    df = df[include_mask & ~exclude_mask].copy()

    if df.empty:
        raise ValueError(
            "No rate-decision events found after filtering calendar. "
            "Check event keywords/ticker mapping."
        )

    grouped = (
        df.groupby("Meeting Date")
        .agg({
            "Event Name": lambda x: " | ".join(sorted(set([str(v) for v in x]))),
            "Release Time": lambda x: " | ".join(sorted(set([str(v) for v in x if str(v) != "nan"]))),
            "Ticker": lambda x: " | ".join(sorted(set([str(v) for v in x if str(v) != "nan"])))
        })
        .reset_index()
    )

    grouped["Type"] = "BQL Central Bank Calendar"
    grouped = grouped.sort_values("Meeting Date").reset_index(drop=True)

    return grouped


def estimate_next_boundary_date(requested_df, country_name):
    cfg = COUNTRY_MAP[country_name]
    fallback_gap = int(cfg.get("fallback_meeting_gap_days", 42))

    dates = requested_df["Meeting Date"].sort_values().tolist()

    if len(dates) >= 2:
        gaps = [
            actual_days(dates[i], dates[i + 1])
            for i in range(len(dates) - 1)
        ]

        gaps = [g for g in gaps if g > 10]

        if len(gaps) > 0:
            gap = int(round(np.median(gaps)))
        else:
            gap = fallback_gap
    else:
        gap = fallback_gap

    return dates[-1] + dt.timedelta(days=gap)


def build_meeting_calendar_for_model(
    country_name,
    effective_lag_days=0,
    boundary_lookahead_days=800
):
    today = dt.date.today()
    year_end = dt.date(today.year, 12, 31)
    pull_end = year_end + dt.timedelta(days=int(boundary_lookahead_days))

    meetings_df = get_central_bank_meetings_bql(
        country_name=country_name,
        start=today,
        end=pull_end,
        verbose=False
    )

    meetings_df["Meeting Date"] = meetings_df["Meeting Date"].apply(to_date)
    meetings_df = meetings_df[meetings_df["Meeting Date"] >= today].copy()
    meetings_df = meetings_df.sort_values("Meeting Date").reset_index(drop=True)

    requested_df = meetings_df[meetings_df["Meeting Date"] <= year_end].copy()
    boundary_candidates = meetings_df[meetings_df["Meeting Date"] > year_end].copy()

    if requested_df.empty:
        raise ValueError(f"No future rate-decision meetings found through year-end {year_end}.")

    requested_df["Requested"] = True
    requested_df["Boundary Only"] = False
    requested_df["Boundary Source"] = ""

    if not boundary_candidates.empty:
        boundary_df = boundary_candidates.iloc[[0]].copy()
        boundary_df["Boundary Source"] = "BQL next rate decision"
    else:
        estimated_boundary_date = estimate_next_boundary_date(requested_df, country_name)

        boundary_df = pd.DataFrame({
            "Meeting Date": [estimated_boundary_date],
            "Event Name": ["Estimated boundary only"],
            "Release Time": [""],
            "Ticker": [""],
            "Type": ["Estimated Boundary"],
            "Boundary Source": ["Estimated from recent meeting cadence"]
        })

    boundary_df["Requested"] = False
    boundary_df["Boundary Only"] = True

    model_df = pd.concat([requested_df, boundary_df], ignore_index=True)
    model_df = model_df.sort_values("Meeting Date").reset_index(drop=True)

    model_df["Effective Date"] = model_df["Meeting Date"].apply(
        lambda x: x + dt.timedelta(days=int(effective_lag_days))
    )

    return model_df, today, year_end


# =========================
# INTERPOLATION ENGINE
# =========================
def interpolation_weight(t, method="Linear", shape=2.0):
    """
    Returns the fraction of the total start-to-end TPM change realized at normalized time t.
    t is clipped to [0, 1].
    """
    if pd.isna(t):
        return np.nan

    t = max(0.0, min(1.0, float(t)))
    method = str(method)

    shape = safe_float(shape, 2.0)

    if not np.isfinite(shape) or shape <= 0:
        shape = 2.0

    if method == "Linear":
        return t

    if method == "Front-loaded":
        return 1.0 - (1.0 - t) ** shape

    if method == "Back-loaded":
        return t ** shape

    if method == "Smoothstep":
        return 3.0 * t ** 2 - 2.0 * t ** 3

    if method == "Jump then flat":
        return 1.0 if t > 0 else 0.0

    if method == "Flat then jump":
        return 0.0 if t < 1.0 else 1.0

    return t


def interpolated_level(start_rate, end_rate, t, method="Linear", shape=2.0):
    """
    Interpolates a policy-rate level between start_rate and end_rate.

    Exponential interpolation is multiplicative:
        start * (end / start) ** t

    For non-positive rates, exponential falls back to linear because log/multiplicative
    interpolation is not well-defined.
    """
    start_rate = float(start_rate)
    end_rate = float(end_rate)

    t = max(0.0, min(1.0, float(t)))
    method = str(method)

    if method == "Exponential":
        if start_rate > 0 and end_rate > 0:
            return start_rate * (end_rate / start_rate) ** t
        else:
            w = t
            return start_rate + w * (end_rate - start_rate)

    w = interpolation_weight(t, method=method, shape=shape)
    return start_rate + w * (end_rate - start_rate)


def interval_avg_daily_log_from_meeting_rates(
    interval_start,
    interval_end,
    start_rate_pct,
    meeting_dates,
    meeting_post_rates,
    basis=360
):
    """
    Calculates average daily log rate across one curve interval.

    Policy is piecewise constant:
    - start_rate applies from interval_start to first meeting.
    - each meeting_post_rate applies from its meeting date to the next meeting / interval end.
    """
    interval_start = to_date(interval_start)
    interval_end = to_date(interval_end)

    total_days = actual_days(interval_start, interval_end)

    if total_days <= 0:
        return np.nan

    meeting_pairs = []

    for d, r in zip(meeting_dates, meeting_post_rates):
        d = to_date(d)

        if interval_start < d < interval_end:
            meeting_pairs.append((d, float(r)))

    meeting_pairs = sorted(meeting_pairs, key=lambda x: x[0])

    segments = []
    seg_start = interval_start
    seg_rate = float(start_rate_pct)

    for meeting_date, post_rate in meeting_pairs:
        days = actual_days(seg_start, meeting_date)

        if days > 0:
            segments.append((days, seg_rate))

        seg_start = meeting_date
        seg_rate = post_rate

    final_days = actual_days(seg_start, interval_end)

    if final_days > 0:
        segments.append((final_days, seg_rate))

    log_sum = 0.0

    for days, rate in segments:
        dl = daily_log_from_annual_pct(rate, basis=basis)

        if not np.isfinite(dl):
            return np.nan

        log_sum += dl * days

    return log_sum / total_days


def solve_scalar_bisection(func, x0, lower=None, upper=None, max_iter=100, tol=1e-12):
    """
    Simple robust scalar solver for monotonic-ish functions.
    Expands brackets around x0 if needed.
    """
    x0 = float(x0)

    if lower is None or upper is None:
        width = 1.0

        if np.isfinite(x0):
            center = x0
        else:
            center = 0.0

        lower = center - width
        upper = center + width

        f_lower = func(lower)
        f_upper = func(upper)

        expand_count = 0

        while np.isfinite(f_lower) and np.isfinite(f_upper) and f_lower * f_upper > 0 and expand_count < 60:
            width *= 2.0
            lower = center - width
            upper = center + width
            f_lower = func(lower)
            f_upper = func(upper)
            expand_count += 1
    else:
        lower = float(lower)
        upper = float(upper)
        f_lower = func(lower)
        f_upper = func(upper)

    f_lower = func(lower)
    f_upper = func(upper)

    if not np.isfinite(f_lower) or not np.isfinite(f_upper):
        raise ValueError("Scalar solver encountered non-finite bracket values.")

    if abs(f_lower) < tol:
        return lower

    if abs(f_upper) < tol:
        return upper

    if f_lower * f_upper > 0:
        # Fallback to a local secant-ish grid search if bracketing fails.
        grid = np.linspace(lower, upper, 2001)
        vals = np.array([func(x) for x in grid], dtype=float)
        valid = np.isfinite(vals)

        if not valid.any():
            raise ValueError("Scalar solver could not find any finite function values.")

        idx = np.nanargmin(np.abs(vals))
        return float(grid[idx])

    for _ in range(max_iter):
        mid = 0.5 * (lower + upper)
        f_mid = func(mid)

        if not np.isfinite(f_mid):
            raise ValueError("Scalar solver encountered non-finite midpoint value.")

        if abs(f_mid) < tol:
            return mid

        if f_lower * f_mid <= 0:
            upper = mid
            f_upper = f_mid
        else:
            lower = mid
            f_lower = f_mid

    return 0.5 * (lower + upper)


def solve_single_meeting_rate_for_interval(
    interval_start,
    interval_end,
    meeting_date,
    start_rate_pct,
    target_avg_daily_log,
    basis=360
):
    """
    Exact solve when there is exactly one meeting in a curve interval.
    One instrument interval gives one equation and one unknown meeting post-rate.
    """
    interval_start = to_date(interval_start)
    interval_end = to_date(interval_end)
    meeting_date = to_date(meeting_date)

    d0 = actual_days(interval_start, meeting_date)
    d1 = actual_days(meeting_date, interval_end)
    total_days = actual_days(interval_start, interval_end)

    if total_days <= 0 or d1 <= 0:
        return np.nan

    start_daily_log = daily_log_from_annual_pct(start_rate_pct, basis=basis)

    solved_daily_log = (
        target_avg_daily_log * total_days - start_daily_log * d0
    ) / d1

    return annual_pct_from_daily_log(solved_daily_log, basis=basis)


def solve_multi_meeting_rates_for_interval(
    interval_start,
    interval_end,
    start_rate_pct,
    meeting_dates,
    target_avg_daily_log,
    method="Linear",
    shape=2.0,
    basis=360
):
    """
    Handles multiple meetings inside one curve interval.

    The model solves for a latent terminal rate at the curve maturity such that
    the piecewise-constant meeting path implied by the chosen interpolation method
    matches the market-implied forward average rate for the interval.

    Then each meeting rate is read off the interpolated path.
    """
    interval_start = to_date(interval_start)
    interval_end = to_date(interval_end)

    total_days = actual_days(interval_start, interval_end)

    if total_days <= 0:
        return [np.nan for _ in meeting_dates], np.nan

    valid_meetings = [
        to_date(d)
        for d in meeting_dates
        if interval_start < to_date(d) < interval_end
    ]

    valid_meetings = sorted(valid_meetings)

    if len(valid_meetings) == 0:
        return [], start_rate_pct

    fwd_rate_guess = annual_pct_from_daily_log(target_avg_daily_log, basis=basis)

    def meeting_rates_from_terminal(end_rate):
        rates = []

        for d in valid_meetings:
            t = actual_days(interval_start, d) / float(total_days)
            r = interpolated_level(
                start_rate=start_rate_pct,
                end_rate=end_rate,
                t=t,
                method=method,
                shape=shape
            )
            rates.append(r)

        return rates

    def objective(end_rate):
        rates = meeting_rates_from_terminal(end_rate)

        avg_log = interval_avg_daily_log_from_meeting_rates(
            interval_start=interval_start,
            interval_end=interval_end,
            start_rate_pct=start_rate_pct,
            meeting_dates=valid_meetings,
            meeting_post_rates=rates,
            basis=basis
        )

        return avg_log - target_avg_daily_log

    terminal_rate = solve_scalar_bisection(
        func=objective,
        x0=fwd_rate_guess
    )

    solved_rates = meeting_rates_from_terminal(terminal_rate)

    return solved_rates, terminal_rate


