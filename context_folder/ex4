def safe_float(x, default=np.nan):
    try:
        return float(x)
    except Exception:
        return default


def _flatten_bql_df(response_item):
    df = response_item.df().copy()
    df = df.reset_index()

    possible_id_cols = ["ID", "index", "security", "Security"]
    id_col = None

    for col in possible_id_cols:
        if col in df.columns:
            id_col = col
            break

    if id_col is None:
        id_col = df.columns[0]

    df = df.rename(columns={id_col: "ID"})
    df = df.loc[:, ~df.columns.duplicated()]
    return df


def _find_col(df, candidates):
    lower_map = {str(c).lower(): c for c in df.columns}

    for candidate in candidates:
        if candidate.lower() in lower_map:
            return lower_map[candidate.lower()]

    for col in df.columns:
        col_lower = str(col).lower()
        for candidate in candidates:
            if candidate.lower() in col_lower:
                return col

    return None


def _first_numeric_col(df, exclude_cols=None):
    if exclude_cols is None:
        exclude_cols = []

    exclude_set = set([str(x).lower() for x in exclude_cols])

    for col in df.columns:
        if str(col).lower() in exclude_set:
            continue

        s = pd.to_numeric(df[col], errors="coerce")

        if s.notna().any():
            return col

    return None


def to_date(x):
    if isinstance(x, pd.Timestamp):
        return x.date()
    if isinstance(x, dt.datetime):
        return x.date()
    return x


def actual_days(start, end):
    start = to_date(start)
    end = to_date(end)
    return (end - start).days


def daily_log_from_annual_pct(rate_pct, basis=360):
    if pd.isna(rate_pct):
        return np.nan

    r = rate_pct / 100.0
    daily_factor = 1.0 + r / float(basis)

    if daily_factor <= 0:
        return np.nan

    return np.log(daily_factor)


def annual_pct_from_daily_log(daily_log_rate, basis=360):
    if pd.isna(daily_log_rate):
        return np.nan

    daily_simple = np.expm1(daily_log_rate)
    annual_decimal = daily_simple * float(basis)
    return annual_decimal * 100.0


def instrument_log_factor_from_annual_pct(rate_pct, tenor_days, basis=360):
    if pd.isna(rate_pct) or tenor_days <= 0:
        return np.nan

    r = rate_pct / 100.0
    T = tenor_days / float(basis)

    factor = 1.0 + r * T

    if factor <= 0:
        return np.nan

    return np.log(factor)


def annual_pct_from_instrument_log_factor(log_factor, tenor_days, basis=360):
    if pd.isna(log_factor) or tenor_days <= 0:
        return np.nan

    T = tenor_days / float(basis)
    factor = np.exp(log_factor)

    annual_decimal = (factor - 1.0) / T
    return annual_decimal * 100.0


def get_chart_end_date(meeting_table, model_meetings_df=None, curve_df=None, buffer_days=30):
    candidates = []

    if meeting_table is not None and not meeting_table.empty:
        if "Segment End" in meeting_table.columns:
            candidates.extend([to_date(x) for x in meeting_table["Segment End"].dropna().tolist()])
        if "Effective Date" in meeting_table.columns:
            candidates.extend([to_date(x) for x in meeting_table["Effective Date"].dropna().tolist()])
        if "Meeting" in meeting_table.columns:
            candidates.extend([to_date(x) for x in meeting_table["Meeting"].dropna().tolist()])

    if len(candidates) == 0 and model_meetings_df is not None and not model_meetings_df.empty:
        if "Effective Date" in model_meetings_df.columns:
            candidates.extend([to_date(x) for x in model_meetings_df["Effective Date"].dropna().tolist()])

    if len(candidates) == 0 and curve_df is not None and not curve_df.empty:
        candidates.extend([x.date() for x in pd.to_datetime(curve_df["maturity"]).dropna().tolist()])

    if len(candidates) == 0:
        return dt.date.today() + dt.timedelta(days=365)

    return max(candidates) + dt.timedelta(days=int(buffer_days))


