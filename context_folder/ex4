        ["Meeting Filter", "BQL central bank calendar; rate-decision events only"],
        ["Solver", diagnostics.get("Solver", "Forward-interval meeting allocation")],
        [
            "Multiple Meetings per Curve Bucket",
            "If more than one central bank meeting falls between two TIIE RFR tenors, "
            "the model solves a terminal bucket rate and allocates meeting levels using "
            "the selected interpolation method."
        ],
        ["Interpolation Method", diagnostics.get("Interpolation Method", "")],
        [
            "Interpolation Shape",
            f"{diagnostics.get('Interpolation Shape', '')}. Used only for Front-loaded "
            "and Back-loaded methods. Shape=2 means quadratic. Linear, Exponential, "
